                    b.BackgroundColor3 = Color3.fromRGB(80, 0, 170)
                end
            end
            startViewMode(entity)
            viewBtn.Text = "✔"
            viewBtn.BackgroundColor3 = Color3.fromRGB(130, 0, 255)
        end
    end)
    
    entryMap[entity] = entry
    sortOrder[entity] = layoutOrder
    EmptyLabel.Visible = false
end

-- ============================================
-- MAIN SCANNER
-- ============================================

local function updateScanner()
    if not scannerActive then return end
    
    local found = scanForEntities()
    local foundSet = {}
    
    for i, entity in ipairs(found) do
        foundSet[entity] = true
        if not entityESPObjects[entity] then
            createESP(entity)
            createListEntry(entity, i)
        end
    end
    
    -- Remove stale
    for entity in pairs(entityESPObjects) do
        if not foundSet[entity] or not entity.Parent then
            removeESP(entity)
            removeListEntry(entity)
        end
    end
    
    -- Update count
    local total = 0
    for _ in pairs(entityESPObjects) do total += 1 end
    CountLabel.Text = "Entities: " .. total
    CountLabel.TextColor3 = total > 0
        and Color3.fromRGB(255, 60, 60)
        or Color3.fromRGB(255, 200, 50)
end

-- Distance update
RunService.Heartbeat:Connect(function()
    if not scannerActive then return end
    
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    for entity, data in pairs(entityESPObjects) do
        if not data.targetPart or not data.targetPart.Parent then
            data.targetPart = entity:FindFirstChild("HumanoidRootPart")
                or entity:FindFirstChild("Head")
                or entity.PrimaryPart
                or entity:FindFirstChildWhichIsA("BasePart")
        end
        
        local tp = data.targetPart
        if tp and tp.Parent then
            local dist = math.floor((root.Position - tp.Position).Magnitude)
            local col = dist < 20 and Color3.fromRGB(255, 50, 50)
                or dist < 60 and Color3.fromRGB(255, 190, 40)
                or Color3.fromRGB(160, 160, 160)
            
            if data.distLabel then
                data.distLabel.Text = dist .. " studs"
                data.distLabel.TextColor3 = col
            end
            
            local ef = entryMap[entity]
            if ef then
                local dl = ef:FindFirstChild("Distance")
                if dl then
                    dl.Text = dist .. " studs"
                    dl.TextColor3 = col
                end
            end
        end
    end
end)

-- Live workspace monitoring
workspace.DescendantAdded:Connect(function(obj)
    if not scannerActive then return end
    task.wait(0.08)
    if isEntity(obj) and not entityESPObjects[obj] then
        createESP(obj)
        local order = 9999
        for ent, o in pairs(sortOrder) do
            if o >= order then order = o + 1 end
        end
        createListEntry(obj, order)
        
        local total = 0
        for _ in pairs(entityESPObjects) do total += 1 end
        CountLabel.Text = "Entities: " .. total
        CountLabel.TextColor3 = Color3.fromRGB(255, 60, 60)
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    if entityESPObjects[obj] then
        removeESP(obj)
        removeListEntry(obj)
        
        local total = 0
        for _ in pairs(entityESPObjects) do total += 1 end
        CountLabel.Text = "Entities: " .. total
    end
end)

