local function scanForDoors()
    aoDoors = {}
    aoDoorTracked = {}
    
    for _, descendant in ipairs(workspace:GetDescendants()) do
        if descendant:IsA("ProximityPrompt") then
            local parentName = descendant.Parent.Name:lower()
            if parentName:find("door") or parentName:find("gate") or parentName:find("entrance") then
                local part = descendant.Parent:IsA("BasePart") and descendant.Parent or descendant.Parent:FindFirstChildWhichIsA("BasePart")
                if part and not aoDoorTracked[descendant] then
                    aoDoorTracked[descendant] = true
                    table.insert(aoDoors, {
                        Prompt = descendant,
                        Part = part,
                        Name = descendant.Parent.Name,
                        Opened = false
                    })
                end
            end
        end
    end
    
    local char = LP.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        table.sort(aoDoors, function(a, b)
            local distA = (root.Position - a.Part.Position).Magnitude
            local distB = (root.Position - b.Part.Position).Magnitude
            return distA < distB
        end)
    end
end

local function getNextUnopedDoor()
    scanForDoors()
    for _, door in ipairs(aoDoors) do
        if not door.Opened and door.Prompt and door.Prompt.Parent then
            return door
        end
    end
    return nil
end

local function aoDoorTick()
    if not aoDoorEnabled then return end
    
    local char = LP.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local now = tick()
    
    if not currentAODoor or not currentAODoor.Prompt or not currentAODoor.Prompt.Parent or currentAODoor.Opened then
        currentAODoor = getNextUnopedDoor()
        if not currentAODoor then
            postLog("AO DOOR: All doors opened or no doors found.")
            aoDoorEnabled = false
            return
        end
    end
    
    local doorPart = currentAODoor.Part
    if not doorPart or not doorPart.Parent then
        currentAODoor = getNextUnopedDoor()
        return
    end
    
    local dist = (root.Position - doorPart.Position).Magnitude
    
    if dist > 5 and now - aoLastTeleport >= aoTeleportDelay then
        root.CFrame = doorPart.CFrame * CFrame.new(0, 0, 3)
        aoLastTeleport = now
        postLog("AO DOOR: Teleporting to " .. currentAODoor.Name)
    end
    
    if dist <= 10 and now - aoLastEPress >= aoEPressDelay then
        UIS:SendKeyEvent(true, Enum.KeyCode.E, false, LP)
        task.wait(0.05)
        UIS:SendKeyEvent(false, Enum.KeyCode.E, false, LP)
        aoLastEPress = now
        currentAODoor.Opened = true
        postLog("AO DOOR: Opened " .. currentAODoor.Name)
    end
end

