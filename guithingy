    NameBtn.BackgroundColor3 = namesOn and Color3.fromRGB(0, 95, 160) or Color3.fromRGB(100, 28, 28)
    for _, d in pairs(tracked) do
        if d.billboard then d.billboard.Enabled = namesOn end
    end
end)

ViewBtn.MouseButton1Click:Connect(function()
    if viewing then stopView(); return end
    local char = LocalPlayer.Character
    local myR = char and char:FindFirstChild("HumanoidRootPart")
    if not myR then return end
    local near, nDist = nil, math.huge
    for ent, d in pairs(tracked) do
        local tp = d.targetPart
        if tp and tp.Parent then
            local dist = (myR.Position - tp.Position).Magnitude
            if dist < nDist then near = ent; nDist = dist end
        end
    end
    if near then
        for _, dd in pairs(tracked) do
            local bb = dd.entry and dd.entry:FindFirstChild("VB")
            if bb then bb.Text = "👁"; bb.BackgroundColor3 = Color3.fromRGB(70, 0, 150) end
        end
        startView(near)
        local nd = tracked[near]
        local bb = nd and nd.entry and nd.entry:FindFirstChild("VB")
        if bb then bb.Text = "✔"; bb.BackgroundColor3 = Color3.fromRGB(115, 0, 235) end
    else
        ViewBtn.Text = "None!"
        ViewBtn.BackgroundColor3 = Color3.fromRGB(130, 20, 20)
        task.delay(1, function()
            if not viewing then
                ViewBtn.Text = "👁 View"
                ViewBtn.BackgroundColor3 = Color3.fromRGB(70, 0, 150)
            end
        end)
    end
end)

