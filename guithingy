    if near then
        for _, dd in pairs(tracked) do
            local bb = dd.entry and dd.entry:FindFirstChild("VB")
            if bb then bb.Text = "👁"; bb.BackgroundColor3 = Color3.fromRGB(70, 0, 150) end
