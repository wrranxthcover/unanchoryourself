-- PERFORMANCE TUNE: LOW-COST NEAREST CLOSET
-- ============================================
local lastClosetScan = 0
local cachedCloset = nil

local function findNearestSafeClosetOptimized()
    if tick() - lastClosetScan < 1.0 and cachedCloset then
        return cachedCloset, (LP.Character.HumanoidRootPart.Position - cachedCloset.PrimaryPart.Position).Magnitude
    end
    
    local char = LP.Character; local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil, math.huge end
    local nearest, minDist = nil, math.huge
    
    -- Limit spatial searches to direct environment only (no deep map scans)
    for _, v in ipairs(workspace:GetChildren()) do
        if v:IsA("Model") and (v.Name:lower():find("locker") or v.Name:lower():find("closet")) then
            local primary = v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart", true)
            if primary then
                local d = (root.Position - primary.Position).Magnitude
                if d < minDist then minDist = d; nearest = v end
            end
        end
    end
    
    lastClosetScan = tick()
    cachedCloset = nearest
    return nearest, minDist
end

local function executeAutoDefend()
    local closet, dist = findNearestSafeClosetOptimized()
    if closet and dist < 120 then
        local targetPart = closet.PrimaryPart or closet:FindFirstChildWhichIsA("BasePart", true)
        if targetPart then
            local char = LP.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart.CFrame = targetPart.CFrame * CFrame.new(0, 0, 1.5)
                showWarning("AUTO-DEFENSE", "0", "Teleported you to nearest closet!", "✦ SAFE")
            end
        end
    end
end

