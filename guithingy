        local bb = nd and nd.entry and nd.entry:FindFirstChild("VB")
        if bb then bb.Text = "✔"; bb.BackgroundColor3 = Color3.fromRGB(115, 0, 235) end
    else
        ViewBtn.Text = "None!"
