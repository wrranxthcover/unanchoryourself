-- MAIN LOOP (v11.1 FIX)
-- ========================================================
local lastHeavyUpdate = 0
local lastRadarUpdate = 0
local mainHeartbeatConn
mainHeartbeatConn = RunService.Heartbeat:Connect(function()
    if not active then return end
    local now = tick()

    if now - lastRadarUpdate >= RADAR_UPDATE_INTERVAL then
        local dt = now - lastRadarUpdate
        lastRadarUpdate = now
        updateRadar(dt)
    end

    if now - lastHeavyUpdate >= HEAVY_UPDATE_INTERVAL then
        lastHeavyUpdate = now
        heavyUpdateTick()
    end
    
    -- Auto Door System (v11.2 NEW)
    aoDoorTick()
end)

