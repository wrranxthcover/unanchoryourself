-- ============================================
-- PATTERNS
-- ============================================
local function matchesEntityPattern(name)
    local dashPos = name:find("%-(%d+)$")
    if dashPos then
        local prefix = name:sub(1, dashPos - 1)
        local num = tonumber(name:sub(dashPos + 1))
        if num and num >= 1 and num <= 2000 then
            local cleaned = prefix:gsub("\195\175", "X"):gsub("\195\143", "X")
            if #cleaned >= 1 and #cleaned <= 3 then
                local stripped = cleaned:gsub("X", "")
                if stripped == "" or stripped:match("^[A-Za-z]+$") then
                    return true
                end
            end
        end
    end
    local mobNum = name:match("^[Mm][Oo][Bb](%d+)$")
    if mobNum then
        local n = tonumber(mobNum)
        if n and n >= 1 and n <= 25 then return true end
    end
    return false
end

local function isMinionName(name)
    local l = name:lower()
    return l == "eye" or l == "mouth"
end

local function getEntityNumber(name)
    return tonumber(name:match("(%d+)$")) or 0
end

local function getEntityPrefix(name)
    if name:match("^[Mm][Oo][Bb]%d+$") then return "MOB" end
    local l = name:lower()
    if l == "eye" or l == "mouth" then return l end
    local dp = name:find("%-(%d+)$")
    if not dp then return name end
    return name:sub(1, dp - 1)
end

local colorCache = {}
local function getEntityColor(name)
    if colorCache[name] then return colorCache[name] end
    local prefix = getEntityPrefix(name)
    local hue = 0
    for i = 1, #prefix do hue = hue + string.byte(prefix, i) * 14 + i * 53 end
    local c = Color3.fromHSV((hue % 360) / 360, 0.85, 1)
    colorCache[name] = c
    return c
end

-- ============================================
-- PLAYER CHECK
-- ============================================
local playerChars = {}
for _, p in ipairs(Players:GetPlayers()) do
    if p.Character then playerChars[p.Character] = true end
    p.CharacterAdded:Connect(function(c) playerChars[c] = true end)
    p.CharacterRemoving:Connect(function(c) playerChars[c] = nil end)
end
Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function(c) playerChars[c] = true end)
    p.CharacterRemoving:Connect(function(c) playerChars[c] = nil end)
end)
Players.PlayerRemoving:Connect(function(p)
    if p.Character then playerChars[p.Character] = nil end
end)

local function isEntity(obj)
    if playerChars[obj] then return false end
    if blacklist[obj.Name] then return false end
    return matchesEntityPattern(obj.Name)
end

local function getEntityPart(obj)
    if obj:IsA("BasePart") then return obj end
    if obj:IsA("Model") then
        return obj:FindFirstChild("HumanoidRootPart")
            or obj:FindFirstChild("Head")
            or obj:FindFirstChild("Torso")
            or obj.PrimaryPart
            or obj:FindFirstChildWhichIsA("BasePart", true)
    end
    return obj:FindFirstChildWhichIsA("BasePart", true)
end

