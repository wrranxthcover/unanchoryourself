end)

-- ============================================
-- DISTANCE + SPEED + COLOR + ALERT
-- ============================================

RunService.Heartbeat:Connect(function()
    if not active then return end
    dFrame += 1; if dFrame < DIST_SKIP then return end; dFrame = 0

    local char = LocalPlayer.Character
    local myR = char and char:FindFirstChild("HumanoidRootPart")
    if not myR then return end
    local myP = myR.Position
    local now = tick()

    local closestRedName = nil
    local closestRedDist = math.huge
    local closestRedSpeed = ""
    local allRed = {}

    for ent, d in pairs(tracked) do
        local tp = d.targetPart
        if not tp or not tp.Parent then tp = getEntityPart(ent); d.targetPart = tp end
        if tp and tp.Parent then
            local dist = math.floor((myP - tp.Position).Magnitude)

            -- Speed calc
            local sd = speedData[ent]
            local speedTxt = ""
            local speedCol = Color3.fromRGB(180, 180, 100)
            if sd then
                local dt = now - sd.lastTime
                if dt > 0.1 then
                    local moved = (tp.Position - sd.lastPos).Magnitude
                    local spd = moved / dt
                    sd.lastPos = tp.Position
                    sd.lastTime = now

                    -- Rolling average (keep last 5)
                    table.insert(sd.samples, spd)
                    if #sd.samples > 5 then table.remove(sd.samples, 1) end
                    local avg = 0
                    for _, s in ipairs(sd.samples) do avg += s end
                    avg = avg / #sd.samples
                    sd.speed = avg

                    if avg >= FAST_THRESHOLD then
                        speedTxt = "⚡ FAST! " .. math.floor(avg) .. "s/s"
                        speedCol = Color3.fromRGB(255, 80, 80)
                    elseif avg >= SLOW_THRESHOLD then
                        speedTxt = "→ Moving " .. math.floor(avg) .. "s/s"
                        speedCol = Color3.fromRGB(255, 200, 80)
                    elseif avg >= 0.5 then
                        speedTxt = "🐌 Slow " .. string.format("%.1f", avg) .. "s/s"
                        speedCol = Color3.fromRGB(120, 180, 120)
                    else
                        speedTxt = "■ Idle"
                        speedCol = Color3.fromRGB(100, 100, 100)
                    end
                end
            else
                speedData[ent] = {lastPos = tp.Position, lastTime = now, speed = 0, samples = {}}
            end

            -- Distance text
            local textCol = dist < 18 and Color3.fromRGB(255, 40, 40) or dist < 50 and Color3.fromRGB(255, 180, 30) or Color3.fromRGB(140, 140, 140)
            if d.distLabel then d.distLabel.Text = dist .. "s"; d.distLabel.TextColor3 = textCol end
            if d.entryDist then d.entryDist.Text = dist .. "s"; d.entryDist.TextColor3 = textCol end

            -- Speed labels
            if d.speedLabel then d.speedLabel.Text = speedTxt; d.speedLabel.TextColor3 = speedCol end
            if d.entrySpeed then d.entrySpeed.Text = speedTxt; d.entrySpeed.TextColor3 = speedCol end

            -- ESP color
            local espColor
            if dist >= 50000 then espColor = Color3.fromRGB(255, 255, 255)
            elseif dist >= 25000 then local t = (dist - 25000) / 25000; espColor = Color3.fromRGB(255, 255, math.floor(255 * t))
            elseif dist >= 10000 then local t = (dist - 10000) / 15000; espColor = Color3.fromRGB(255, math.floor(140 + 115 * t), 0)
            else local t = math.clamp(dist / 10000, 0, 1); espColor = Color3.fromRGB(255, math.floor(140 * t), 0) end

            if d.highlight then d.highlight.FillColor = espColor; d.highlight.OutlineColor = espColor end
            if d.nameLabel then d.nameLabel.TextColor3 = espColor end
            if d.entryName then d.entryName.TextColor3 = espColor end
            if d.entryStroke then d.entryStroke.Color = espColor end
            if d.entryDot then d.entryDot.BackgroundColor3 = espColor end

                        -- Red alert tracking (ONLY if approaching)
            if dist < RED_THRESHOLD and matchesEntityPattern(ent.Name) then
                local isApproaching = false
                if sd and #sd.samples > 0 then
                    -- Check if distance is decreasing
                    local prevDist = (myP - sd.lastPos).Magnitude
                    -- If entity is closer now than its movement direction suggests
                    -- Simple: check if entity is moving TOWARD player
                    local entPos = tp.Position
                    local toPlayer = (myP - entPos).Unit
                    local entVelocity = Vector3.zero
                    if sd.prevPos then
                        local dt2 = now - (sd.prevTime or now)
                        if dt2 > 0 then
                            entVelocity = (entPos - sd.prevPos) / dt2
                        end
                    end
                    -- Dot product: positive = moving toward player
                    local dot = entVelocity.Unit:Dot(toPlayer)
                    isApproaching = dot > 0.1 or sd.speed < 0.5 -- approaching or idle nearby
                    
                    sd.prevPos = entPos
                    sd.prevTime = now
                else
                    -- No speed data yet, assume approaching to be safe
                    isApproaching = true
                    if sd then
                        sd.prevPos = tp.Position
                        sd.prevTime = now
                    end
                end

                if isApproaching then
                    allRed[ent.Name] = dist
                    if dist < closestRedDist then
                        closestRedName = ent.Name
                        closestRedDist = dist
                        closestRedSpeed = speedTxt
                    end
                end
            end

    if closestRedName then
        showAlert(closestRedName, closestRedDist, allRed, closestRedSpeed)
    else
        hideAlert()
    end
end)

