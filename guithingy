-- Global console reference
local consoleLogs = nil

local function postLog(msg)
    if consoleLogs then
        local lines = string.split(consoleLogs.Text, "\n")
        if #lines >= 8 then table.remove(lines, 1) end
        table.insert(lines, msg:upper())
        consoleLogs.Text = table.concat(lines, "\n")
    end
    print("[SCANNER LOG] " .. msg)
end

