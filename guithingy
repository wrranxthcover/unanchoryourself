-- ============================================
-- VIEW MODE (free movement HUD)
-- ============================================

local viewIndicator = nil

local function stopView()
    viewing = false
    if viewConn then viewConn:Disconnect(); viewConn = nil end
    if viewIndicator then
        pcall(function() viewIndicator:Destroy() end)
        viewIndicator = nil
    end
    VP.Visible = false
    ViewBtn.BackgroundColor3 = Color3.fromRGB(70, 0, 150)
    ViewBtn.Text = "👁 View"
    for _, d in pairs(tracked) do
        local b = d.entry and d.entry:FindFirstChild("VB")
        if b then b.Text = "👁"; b.BackgroundColor3 = Color3.fromRGB(70, 0, 150) end
    end
    viewTarget = nil
end

local function startView(entity)
    if viewing then stopView() end

    local data = tracked[entity]
    if not data then return end

    local root = data.targetPart
    if not root or not root.Parent then
        root = entity:FindFirstChildWhichIsA("BasePart")
        data.targetPart = root
    end
    if not root then return end

    viewing = true
    viewTarget = entity
    VP.Visible = true
    VL.Text = "👁 " .. entity.Name
    ViewBtn.Text = "👁 ..."
    ViewBtn.BackgroundColor3 = Color3.fromRGB(115, 0, 235)

    -- Create floating indicator
    local indicator = Instance.new("ScreenGui")
    indicator.Name = "ViewIndicator"
    indicator.ResetOnSpawn = false
    indicator.DisplayOrder = 100
    indicator.Parent = LocalPlayer.PlayerGui

    local arrow = Instance.new("TextLabel")
    arrow.Name = "Arrow"
    arrow.Size = UDim2.new(0, 160, 0, 50)
    arrow.AnchorPoint = Vector2.new(0.5, 0)
    arrow.Position = UDim2.new(0.5, 0, 0, 8)
    arrow.BackgroundColor3 = Color3.fromRGB(15, 0, 35)
    arrow.BackgroundTransparency = 0.2
    arrow.Text = "⚠ " .. entity.Name .. "\n? studs"
    arrow.TextColor3 = getEntityColor(entity.Name)
    arrow.TextSize = 13
    arrow.Font = Enum.Font.GothamBold
    arrow.TextStrokeTransparency = 0.3
    arrow.TextStrokeColor3 = Color3.new(0, 0, 0)
    arrow.Parent = indicator
    Instance.new("UICorner", arrow).CornerRadius = UDim.new(0, 6)

    local arrowStroke = Instance.new("UIStroke")
    arrowStroke.Color = getEntityColor(entity.Name)
    arrowStroke.Thickness = 1.5
    arrowStroke.Transparency = 0.3
    arrowStroke.Parent = arrow

    viewIndicator = indicator

    local frameSkip = 0
    viewConn = RunService.Heartbeat:Connect(function()
        if not viewing or not entity or not entity.Parent then
            stopView()
            return
        end

        if not root or not root.Parent then
            root = entity:FindFirstChildWhichIsA("BasePart")
            data.targetPart = root
            if not root then stopView(); return end
        end

        frameSkip += 1
        if frameSkip < 3 then return end
        frameSkip = 0

        local screenPos, onScreen = Camera:WorldToScreenPoint(root.Position)
        local vp = Camera.ViewportSize

        local char = LocalPlayer.Character
        local myRoot = char and char:FindFirstChild("HumanoidRootPart")
        local distText = "?"
        if myRoot then
            distText = math.floor((myRoot.Position - root.Position).Magnitude) .. " studs"
        end

        arrow.Text = "⚠ " .. entity.Name .. "\n" .. distText

        if onScreen then
            local sx = math.clamp(screenPos.X, 80, vp.X - 80)
            local sy = math.clamp(screenPos.Y, 8, 60)
            arrow.Position = UDim2.new(0, sx, 0, sy)
        else
            local dir = (root.Position - Camera.CFrame.Position).Unit
            local camRight = Camera.CFrame.RightVector
            local dot = camRight:Dot(dir)
            arrow.Position = UDim2.new(dot > 0 and 1 or 0, dot > 0 and -90 or 10, 0, 8)
        end
    end)
end

-- ============================================
-- TRACK / UNTRACK
-- ============================================

local function untrack(entity)
    local d = tracked[entity]
    if not d then return end
    pcall(function() if d.highlight then d.highlight:Destroy() end end)
    pcall(function() if d.billboard then d.billboard:Destroy() end end)
    if d.destroyConn then d.destroyConn:Disconnect() end
    pcall(function() if d.entry then d.entry:Destroy() end end)
    tracked[entity] = nil
    entCount = math.max(0, entCount - 1)
    CL.Text = "Entities: " .. entCount
    CL.TextColor3 = entCount > 0 and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(255, 190, 40)
    EL.Visible = entCount == 0
    if viewTarget == entity then stopView() end
end

local function track(entity)
    if tracked[entity] then return end

    local color = getEntityColor(entity.Name)
    local d = {}

    -- Highlight
    local hl = Instance.new("Highlight")
    hl.Adornee = entity
    hl.FillColor = color
    hl.FillTransparency = 0.55
    hl.OutlineColor = color
    hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Enabled = espOn
    hl.Parent = entity
    d.highlight = hl

    -- Root
    local root = entity:FindFirstChild("HumanoidRootPart")
        or entity:FindFirstChild("Head")
        or entity:FindFirstChild("Torso")
        or entity.PrimaryPart
        or entity:FindFirstChildWhichIsA("BasePart")
    d.targetPart = root

    -- Billboard
    if root then
        local bb = Instance.new("BillboardGui")
        bb.Adornee = root
        bb.Size = UDim2.new(0, 120, 0, 38)
        bb.StudsOffset = Vector3.new(0, 3.5, 0)
        bb.AlwaysOnTop = true
        bb.MaxDistance = 600
        bb.Enabled = namesOn
        bb.Parent = root

        local nt = Instance.new("TextLabel")
        nt.Size = UDim2.new(1, 0, 0.55, 0)
        nt.BackgroundTransparency = 1
        nt.Text = "⚠ " .. entity.Name
        nt.TextColor3 = color
        nt.TextSize = 13
        nt.Font = Enum.Font.GothamBold
        nt.TextStrokeTransparency = 0.1
        nt.TextStrokeColor3 = Color3.new(0, 0, 0)
        nt.Parent = bb

        local dt = Instance.new("TextLabel")
        dt.Name = "DL"
        dt.Size = UDim2.new(1, 0, 0.4, 0)
        dt.Position = UDim2.new(0, 0, 0.55, 0)
        dt.BackgroundTransparency = 1
        dt.Text = "?"
        dt.TextColor3 = Color3.fromRGB(170, 170, 170)
        dt.TextSize = 10
        dt.Font = Enum.Font.GothamSemibold
        dt.TextStrokeTransparency = 0.3
        dt.TextStrokeColor3 = Color3.new(0, 0, 0)
        dt.Parent = bb

        d.billboard = bb
        d.distLabel = dt
    end

    -- List entry
    local num = getEntityNumber(entity.Name)
    local letters = getEntityLetters(entity.Name):upper()
    local sortVal = 0
    for i = 1, #letters do
        sortVal = sortVal * 27 + (string.byte(letters, i) - 64)
    end
    sortVal = sortVal * 2001 + num

    local entry = Instance.new("Frame")
    entry.Size = UDim2.new(1, -4, 0, 30)
    entry.BackgroundColor3 = Color3.fromRGB(16, 16, 34)
    entry.BorderSizePixel = 0
    entry.LayoutOrder = sortVal
    entry.Parent = Scroll
    Instance.new("UICorner", entry).CornerRadius = UDim.new(0, 4)

    local es = Instance.new("UIStroke")
    es.Color = color
    es.Thickness = 1
    es.Transparency = 0.5
    es.Parent = entry

    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0, 5, 0, 5)
    dot.Position = UDim2.new(0, 5, 0.5, -2)
    dot.BackgroundColor3 = color
    dot.BorderSizePixel = 0
    dot.Parent = entry
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local nl = Instance.new("TextLabel")
    nl.Size = UDim2.new(0.5, -14, 0.5, 0)
    nl.Position = UDim2.new(0, 14, 0, 1)
    nl.BackgroundTransparency = 1
    nl.Text = entity.Name
    nl.TextColor3 = color
    nl.TextSize = 10
    nl.Font = Enum.Font.GothamBold
    nl.TextXAlignment = Enum.TextXAlignment.Left
    nl.TextTruncate = Enum.TextTruncate.AtEnd
    nl.Parent = entry

    local edl = Instance.new("TextLabel")
    edl.Name = "EDL"
    edl.Size = UDim2.new(0.5, -14, 0.5, 0)
    edl.Position = UDim2.new(0, 14, 0.5, -1)
    edl.BackgroundTransparency = 1
    edl.Text = "..."
    edl.TextColor3 = Color3.fromRGB(80, 80, 110)
    edl.TextSize = 8
    edl.Font = Enum.Font.Gotham
    edl.TextXAlignment = Enum.TextXAlignment.Left
    edl.Parent = entry

    local vb = Instance.new("TextButton")
    vb.Name = "VB"
    vb.Size = UDim2.new(0, 28, 0, 18)
    vb.Position = UDim2.new(1, -33, 0.5, -9)
    vb.BackgroundColor3 = Color3.fromRGB(70, 0, 150)
    vb.Text = "👁"
    vb.TextColor3 = Color3.fromRGB(255, 255, 255)
    vb.TextSize = 10
    vb.Font = Enum.Font.GothamBold
    vb.BorderSizePixel = 0
    vb.Parent = entry
    Instance.new("UICorner", vb).CornerRadius = UDim.new(0, 3)

    vb.MouseButton1Click:Connect(function()
        if viewTarget == entity then
            stopView()
        else
            for _, dd in pairs(tracked) do
                local bb = dd.entry and dd.entry:FindFirstChild("VB")
                if bb then bb.Text = "👁"; bb.BackgroundColor3 = Color3.fromRGB(70, 0, 150) end
            end
            startView(entity)
            vb.Text = "✔"
            vb.BackgroundColor3 = Color3.fromRGB(115, 0, 235)
        end
    end)

    d.entry = entry
    d.entryDist = edl

    d.destroyConn = entity.AncestryChanged:Connect(function(_, parent)
        if not parent then untrack(entity) end
    end)

    tracked[entity] = d
    entCount += 1
    CL.Text = "Entities: " .. entCount
    CL.TextColor3 = Color3.fromRGB(255, 50, 50)
    EL.Visible = false
end

-- ============================================
-- INITIAL SCAN
-- ============================================

local function initialScan()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if isEntity(obj) then track(obj) end
    end
end

-- ============================================
-- LIVE DETECTION
-- ============================================

workspace.DescendantAdded:Connect(function(obj)
    if not active or not obj:IsA("Model") then return end
    task.defer(function()
        if obj.Parent and isEntity(obj) and not tracked[obj] then
            track(obj)
        end
    end)
end)

workspace.DescendantRemoving:Connect(function(obj)
    if tracked[obj] then untrack(obj) end
end)

-- ============================================
-- DISTANCE UPDATE (throttled)
-- ============================================

RunService.Heartbeat:Connect(function()
    if not active then return end
    dFrame += 1
    if dFrame < DIST_SKIP then return end
    dFrame = 0

    local char = LocalPlayer.Character
    local myR = char and char:FindFirstChild("HumanoidRootPart")
    if not myR then return end
    local myP = myR.Position

    for ent, d in pairs(tracked) do
        local tp = d.targetPart
        if not tp or not tp.Parent then
            tp = ent:FindFirstChildWhichIsA("BasePart")
            d.targetPart = tp
        end
        if tp and tp.Parent then
            local dist = math.floor((myP - tp.Position).Magnitude)
            local col = dist < 18 and Color3.fromRGB(255, 40, 40)
                or dist < 50 and Color3.fromRGB(255, 180, 30)
                or Color3.fromRGB(140, 140, 140)
            local txt = dist .. "s"
            if d.distLabel then d.distLabel.Text = txt; d.distLabel.TextColor3 = col end
            if d.entryDist then d.entryDist.Text = txt; d.entryDist.TextColor3 = col end
        end
    end
end)

