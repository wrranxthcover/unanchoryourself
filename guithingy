        local b = d.entry and d.entry:FindFirstChild("VEB")
        if b then b.Text = "🎥"; b.BackgroundColor3 = Color3.fromRGB(20, 80, 40) end
    end
    viewEntityTarget = nil
end

-- ============================================
-- VIEW ENTITY
-- ============================================
local function startViewEntity(entity)
    if viewingEntity then stopViewEntity() end
    local data = tracked[entity]; if not data then return end
    local root = data.targetPart; if not root or not root.Parent then root = getEntityPart(entity); data.targetPart = root end
    if not root then return end; if viewing then stopView() end
    viewingEntity = true; viewEntityTarget = entity; VEP.Visible = true; VEL.Text = "🎥 " .. entity.Name
    VEBtn.Text = "🎥 ON"; VEBtn.BackgroundColor3 = Color3.fromRGB(0, 140, 50)
    savedCameraType = Camera.CameraType; Camera.CameraType = Enum.CameraType.Scriptable
