local function removeListEntry(entity)
    if entryMap[entity] then
        pcall(function() entryMap[entity]:Destroy() end)
        entryMap[entity] = nil
    end
    -- Show no-entity label if empty
    local count = 0
    for _ in pairs(entryMap) do count = count + 1 end
    NoEntityLabel.Visible = count == 0
end

-- ============================================
-- MAIN SCAN LOOP
-- ============================================

local function updateScanner()
    if not scannerActive then return end

    local found = scanForEntities()
    local foundSet = {}

    for _, entity in pairs(found) do
        foundSet[entity] = true
        if not entityESPObjects[entity] then
            createESP(entity)
            createListEntry(entity)
        end
    end

    -- Remove stale
    for entity in pairs(entityESPObjects) do
        if not foundSet[entity] or not entity.Parent then
            removeESP(entity)
            removeListEntry(entity)
        end
    end

    -- Count
    local total = 0
    for _ in pairs(entityESPObjects) do total = total + 1 end
    EntityCountLabel.Text = "Entities Detected: " .. total
    EntityCountLabel.TextColor3 = total > 0
        and Color3.fromRGB(255, 80, 80)
        or Color3.fromRGB(255, 200, 50)
end

-- Distance heartbeat
RunService.Heartbeat:Connect(function()
    if not scannerActive then return end

    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    for entity, data in pairs(entityESPObjects) do
        local tp = data.targetPart
        if not tp or not tp.Parent then
            tp = entity:FindFirstChild("HumanoidRootPart")
                or entity:FindFirstChild("Head")
                or entity.PrimaryPart
                or entity:FindFirstChildWhichIsA("BasePart")
            data.targetPart = tp
        end

        if tp and tp.Parent then
            local dist = math.floor((root.Position - tp.Position).Magnitude)
            local distText = dist .. " studs"
            local distColor = dist < 25 and Color3.fromRGB(255, 60, 60)
                or dist < 70 and Color3.fromRGB(255, 200, 50)
                or Color3.fromRGB(180, 180, 180)

            if data.distLabel then
                data.distLabel.Text = distText
                data.distLabel.TextColor3 = distColor
            end

            local ef = entryMap[entity]
            if ef then
                local dl = ef:FindFirstChild("Distance")
                if dl then
                    dl.Text = distText .. " away"
                    dl.TextColor3 = distColor
                end
            end
        end
    end
end)

