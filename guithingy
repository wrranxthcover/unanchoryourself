local function untrack(entity)
    local d = tracked[entity]
    if not d then return end
    pcall(function() if d.highlight then d.highlight:Destroy() end end)
    pcall(function() if d.billboard then d.billboard:Destroy() end end)
    if d.destroyConn then d.destroyConn:Disconnect() end
    if d.childConn then d.childConn:Disconnect() end
    pcall(function() if d.entry then d.entry:Destroy() end end)
    speedData[entity] = nil
    tracked[entity] = nil
    entCount = math.max(0, entCount - 1)
    CL.Text = "Entities: " .. entCount
    CL.TextColor3 = entCount > 0 and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(255, 190, 40)
    EL.Visible = entCount == 0
    if viewTarget == entity then stopView() end
    if viewEntityTarget == entity then stopViewEntity() end
    if alertEntity == entity.Name then hideAlert() end
end

