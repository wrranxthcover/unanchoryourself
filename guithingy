-- Distance + Speed + Idle + Alert
RunService.Heartbeat:Connect(function()
    if not active then return end; dF += 1; if dF < dSkip then return end; dF = 0
    local char = LP.Character; local myR = char and char:FindFirstChild("HumanoidRootPart"); if not myR then return end
    local myP = myR.Position; local now = tick(); local cRN, cRD, cRS = nil, math.huge, ""; local allR = {}

    for ent, d in pairs(tracked) do
        local tp = d.targetPart; if not tp or not tp.Parent then tp = getPart(ent); d.targetPart = tp end
        if tp and tp.Parent then
            local dist = math.floor((myP-tp.Position).Magnitude)
            local sd = spd[ent]; local sTxt, sCol = "", Color3.fromRGB(180,180,100)
            if sd then local dt = now - sd.lT
                if dt > 0.1 then
                    local s = (tp.Position-sd.lP).Magnitude/dt; sd.lP = tp.Position; sd.lT = now
                    table.insert(sd.sa, s); if #sd.sa > 5 then table.remove(sd.sa, 1) end
                    local avg = 0; for _, v in ipairs(sd.sa) do avg += v end; avg = avg/#sd.sa; sd.sp = avg
                    if avg >= FAST_THRESH then sTxt = "⚡FAST "..math.floor(avg); sCol = Color3.fromRGB(255,80,80)
                    elseif avg >= SLOW_THRESH then sTxt = "→ "..math.floor(avg); sCol = Color3.fromRGB(255,200,80)
                    elseif avg >= 0.5 then sTxt = "🐌 "..string.format("%.1f", avg); sCol = Color3.fromRGB(120,180,120)
                    else
                        if not sd.idleCheck or now - sd.idleCheck > 1 then sd.idleCheck = now
                            sd.idleState = "■ Idle"; sd.idleCol = Color3.fromRGB(100,100,100)
                            local desp = false
                            if tp.Transparency > 0.3 then desp = true end
                            if not sd.lSize then sd.lSize = tp.Size end
                            if tp.Size.Magnitude < sd.lSize.Magnitude * 0.8 then desp = true end; sd.lSize = tp.Size
                            if ent.Parent and ent.Parent.Name:lower():find("debris") then desp = true end
                            local hum = ent:FindFirstChildWhichIsA("Humanoid"); if hum and hum.Health <= 0 then desp = true end
                            if tp.Position.Y < -50 then desp = true end
                            if desp then sd.idleState = "💨 Despawning!"; sd.idleCol = Color3.fromRGB(150,80,255)
                            else local nL, nT = false, false
                                local ok, nearby = pcall(function() return workspace:GetPartBoundsInRadius(tp.Position, 8) end)
                                if ok and nearby then for _, part in ipairs(nearby) do if part ~= tp then local pn = part.Name:lower()
                                    if pn:find("locker") or pn:find("closet") or pn:find("wardrobe") or pn:find("cabinet") or pn:find("hide") then nL = true end
                                    if pn:find("table") or pn:find("desk") or pn:find("shelf") or pn:find("drawer") then nT = true end
                                end end end
                                if nL then sd.idleState = "🚪 Checking Locker!"; sd.idleCol = Color3.fromRGB(255,150,50)
                                elseif nT then sd.idleState = "🪑 Checking Table!"; sd.idleCol = Color3.fromRGB(200,180,80) end
                            end
                        end; sTxt = sd.idleState or "■ Idle"; sCol = sd.idleCol or Color3.fromRGB(100,100,100) end end
            else spd[ent] = {lP=tp.Position, lT=now, sp=0, sa={}, pP=tp.Position, pT=now,
                idleCheck=0, idleState="■ Idle", idleCol=Color3.fromRGB(100,100,100), lSize=tp.Size,
                forceLastPos=tp.Position, lastMoveDir=nil} end

            local tc = dist<18 and Color3.fromRGB(255,40,40) or dist<50 and Color3.fromRGB(255,180,30) or Color3.fromRGB(140,140,140)
            if d.distLabel then d.distLabel.Text = dist.."s"; d.distLabel.TextColor3 = tc end
            if d.entryDist then d.entryDist.Text = dist.."s"; d.entryDist.TextColor3 = tc end
            if d.speedLabel then d.speedLabel.Text = sTxt; d.speedLabel.TextColor3 = sCol end
            if d.entrySpeed then d.entrySpeed.Text = sTxt; d.entrySpeed.TextColor3 = sCol end

            local ec
            if dist >= 50000 then ec = Color3.fromRGB(255,255,255)
            elseif dist >= 25000 then local t = (dist-25000)/25000; ec = Color3.fromRGB(255,255,math.floor(255*t))
            elseif dist >= 10000 then local t = (dist-10000)/15000; ec = Color3.fromRGB(255,math.floor(140+115*t),0)
            else local t = math.clamp(dist/10000,0,1); ec = Color3.fromRGB(255,math.floor(140*t),0) end
            if d.highlight then d.highlight.FillColor = ec; d.highlight.OutlineColor = ec end
            if d.nameLabel then d.nameLabel.TextColor3 = ec end; if d.entryName then d.entryName.TextColor3 = ec end
            if d.entryStroke then d.entryStroke.Color = ec end; if d.entryDot then d.entryDot.BackgroundColor3 = ec end

            if dist < RED_THRESH and matchPat(ent.Name) then local appr = true
                if sd and sd.pP then local toP = (myP-tp.Position).Unit; local vel = Vector3.zero
                    local pdt = now-(sd.pT or now); if pdt > 0 then vel = (tp.Position-sd.pP)/pdt end
                    if vel.Magnitude > 0.5 then appr = vel.Unit:Dot(toP) > 0.1 end; sd.pP = tp.Position; sd.pT = now end
                if appr then allR[ent.Name] = dist; if dist < cRD then cRN = ent.Name; cRD = dist; cRS = sTxt end end end
        end
    end
    if cRN then showAl(cRN, cRD, allR, cRS) else hideAl() end
end)

