local function stopView()
    viewing = false
    if viewConn then viewConn:Disconnect(); viewConn = nil end
    if viewIndicator then
        pcall(function() viewIndicator:Destroy() end)
        viewIndicator = nil
    end
    VP.Visible = false
    ViewBtn.BackgroundColor3 = Color3.fromRGB(70, 0, 150)
    ViewBtn.Text = "👁 View"
    for _, d in pairs(tracked) do
        local b = d.entry and d.entry:FindFirstChild("VB")
        if b then b.Text = "👁"; b.BackgroundColor3 = Color3.fromRGB(70, 0, 150) end
    end
    viewTarget = nil
end

-- ============================================
-- STOP VIEW ENTITY
-- ============================================

local function stopViewEntity()
    viewingEntity = false
    if viewEntityConn then viewEntityConn:Disconnect(); viewEntityConn = nil end

    if savedCameraType then
        Camera.CameraType = savedCameraType
        savedCameraType = nil
    else
        Camera.CameraType = Enum.CameraType.Custom
    end

    -- Reset camera to player
    local char = LocalPlayer.Character
    if char then
        local head = char:FindFirstChild("Head")
        if head then
            Camera.CFrame = CFrame.new(head.Position + Vector3.new(0, 2, 8), head.Position)
        end
    end

    VEP.Visible = false
    VEBtn.Text = "🎥 View Entity: OFF"
    VEBtn.BackgroundColor3 = Color3.fromRGB(30, 60, 30)

    for _, d in pairs(tracked) do
        local b = d.entry and d.entry:FindFirstChild("VEB")
        if b then b.Text = "🎥"; b.BackgroundColor3 = Color3.fromRGB(20, 80, 40) end
    end
    viewEntityTarget = nil
end

-- ============================================
-- START VIEW ENTITY
-- Auto-follows entity, camera stays close
-- NO right-click needed, fully automatic
-- ============================================

local function startViewEntity(entity)
    if viewingEntity then stopViewEntity() end

    local data = tracked[entity]
    if not data then return end

    local root = data.targetPart
    if not root or not root.Parent then
        root = getEntityPart(entity)
        data.targetPart = root
    end
    if not root then return end

    if viewing then stopView() end

    viewingEntity = true
    viewEntityTarget = entity

    VEP.Visible = true
    VEL.Text = "🎥 " .. entity.Name
    VEBtn.Text = "🎥 View Entity: ON"
    VEBtn.BackgroundColor3 = Color3.fromRGB(0, 140, 50)

    savedCameraType = Camera.CameraType
    Camera.CameraType = Enum.CameraType.Scriptable

    -- Auto orbit angle
    local angle = 0
    local CLOSE_DIST = 12  -- how close the camera stays
    local HEIGHT = 5       -- camera height above entity
    local ORBIT_SPEED = 0.3 -- slow auto-rotate

    viewEntityConn = RunService.Heartbeat:Connect(function(dt)
        if not viewingEntity or not entity or not entity.Parent then
            stopViewEntity()
            return
        end

        if not root or not root.Parent then
            root = getEntityPart(entity)
            data.targetPart = root
            if not root then stopViewEntity(); return end
        end

        -- Auto rotate around entity
        angle = angle + dt * ORBIT_SPEED

        local targetPos = root.Position
        local camPos = targetPos + Vector3.new(
            math.sin(angle) * CLOSE_DIST,
            HEIGHT,
            math.cos(angle) * CLOSE_DIST
        )

        -- Smooth camera
        Camera.CFrame = Camera.CFrame:Lerp(
            CFrame.lookAt(camPos, targetPos),
            0.08
        )

        -- Update distance label
        local char = LocalPlayer.Character
        local myR = char and char:FindFirstChild("HumanoidRootPart")
        if myR then
            local dist = math.floor((myR.Position - root.Position).Magnitude)
            VEL.Text = "🎥 " .. entity.Name .. " | " .. dist .. "s"
        end
    end)
end

