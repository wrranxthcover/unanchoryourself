-- Entity colors
local ENTITY_COLORS = {
    ["Rush"] = Color3.fromRGB(255, 0, 0),
    ["Ambush"] = Color3.fromRGB(255, 80, 0),
    ["Screech"] = Color3.fromRGB(200, 0, 200),
    ["Halt"] = Color3.fromRGB(255, 255, 0),
    ["Eyes"] = Color3.fromRGB(150, 0, 255),
    ["Seek"] = Color3.fromRGB(20, 20, 20),
    ["Figure"] = Color3.fromRGB(100, 0, 0),
    ["Glitch"] = Color3.fromRGB(0, 255, 100),
    ["Jack"] = Color3.fromRGB(255, 150, 0),
    ["Timothy"] = Color3.fromRGB(139, 90, 43),
    ["Shadow"] = Color3.fromRGB(80, 80, 120),
    ["Snare"] = Color3.fromRGB(0, 160, 0),
    ["Dupe"] = Color3.fromRGB(180, 0, 180),
    ["A-60"] = Color3.fromRGB(255, 30, 30),
    ["A-90"] = Color3.fromRGB(255, 60, 60),
    ["A-120"] = Color3.fromRGB(255, 90, 90),
    ["RushMoving"] = Color3.fromRGB(255, 0, 0),
    ["AmbushMoving"] = Color3.fromRGB(255, 50, 0),
    ["Default"] = Color3.fromRGB(255, 80, 80),
}

local ENTITY_PATTERNS = {
    "Rush", "Ambush", "Screech", "Halt", "Eyes", "Seek", "Figure",
    "Glitch", "Jack", "Timothy", "Shadow", "Snare", "Dupe",
    "A-60", "A-90", "A-120", "RushMoving", "AmbushMoving",
    "Entity", "Monster", "Creature", "Ghost", "Demon"
}

local function getEntityColor(name)
    for key, color in pairs(ENTITY_COLORS) do
        if string.find(name:lower(), key:lower()) then
            return color
        end
    end
    return ENTITY_COLORS["Default"]
end

local function isEntity(obj)
    local name = obj.Name:lower()
    for _, pattern in ipairs(ENTITY_PATTERNS) do
        if string.find(name, pattern:lower()) then
            return true
        end
    end
    if obj:IsA("Model") then
        for _, player in pairs(Players:GetPlayers()) do
            if player.Character == obj then return false end
        end
        local hasPart = obj:FindFirstChild("HumanoidRootPart")
            or obj:FindFirstChild("Head")
            or obj:FindFirstChild("Torso")
            or obj.PrimaryPart
        if hasPart then
            local hasHumanoid = obj:FindFirstChildOfClass("Humanoid")
            local hasAnimController = obj:FindFirstChildOfClass("AnimationController")
            if hasHumanoid or hasAnimController then
                local isPlayer = false
                for _, player in pairs(Players:GetPlayers()) do
                    if player.Character == obj then
                        isPlayer = true
                        break
                    end
                end
                if not isPlayer then return true end
            end
        end
    end
    return false
end

local function getEntityContainers()
    local containers = {}
    local possiblePaths = {
        workspace,
        workspace:FindFirstChild("Entities"),
        workspace:FindFirstChild("Entity"),
        workspace:FindFirstChild("Monsters"),
        workspace:FindFirstChild("CurrentRooms"),
        workspace:FindFirstChild("Rooms"),
        workspace:FindFirstChild("Map"),
    }
    for _, container in pairs(possiblePaths) do
        if container then
            table.insert(containers, container)
        end
    end
    return containers
end

-- ============================================
-- VIEW MODE FUNCTIONS
-- ============================================

local originalCameraType = Enum.CameraType.Custom
local originalCameraCFrame = CFrame.new()

local function stopViewMode()
    viewModeActive = false
    currentlyViewing = nil

    if viewConnection then
        viewConnection:Disconnect()
        viewConnection = nil
    end

    -- Restore camera
    Camera.CameraType = Enum.CameraType.Custom
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            Camera.CameraSubject = humanoid
        end
    end

    ViewPanel.Visible = false
    ViewModeToggle.BackgroundColor3 = Color3.fromRGB(80, 0, 180)
    ViewModeToggle.Text = "👁 View"

    print("[Entity Scanner] View mode stopped.")
end

local function startViewMode(entity)
    if viewModeActive then
        stopViewMode()
    end

    local targetPart = entity:FindFirstChild("HumanoidRootPart")
        or entity:FindFirstChild("Head")
        or entity:FindFirstChild("Torso")
        or entity.PrimaryPart
        or (entity:IsA("Model") and entity:FindFirstChildWhichIsA("BasePart"))

    if not targetPart then
        warn("[Entity Scanner] Could not find a part to view on: " .. entity.Name)
        return
    end

    viewModeActive = true
    currentlyViewing = entity

    -- Update UI
    ViewPanel.Visible = true
    ViewingLabel.Text = "👁 Viewing: " .. entity.Name
    ViewModeToggle.BackgroundColor3 = Color3.fromRGB(160, 0, 255)
    ViewModeToggle.Text = "👁 Viewing..."

    -- Switch camera to scriptable and follow entity
    originalCameraType = Camera.CameraType
    Camera.CameraType = Enum.CameraType.Scriptable

    -- Smooth tween to entity first
    local startCF = Camera.CFrame
    local targetCF = CFrame.new(
        targetPart.Position + Vector3.new(0, 8, 16),
        targetPart.Position
    )

    local tweenInfo = TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = TweenService:Create(Camera, tweenInfo, {CFrame = targetCF})
    tween:Play()

    -- After tween, start live follow
    tween.Completed:Connect(function()
        if not viewModeActive or currentlyViewing ~= entity then return end

        -- Follow camera loop
        viewConnection = RunService.RenderStepped:Connect(function()
            if not viewModeActive or not entity or not entity.Parent then
                stopViewMode()
                return
            end

            if not targetPart or not targetPart.Parent then
                targetPart = entity:FindFirstChild("HumanoidRootPart")
                    or entity:FindFirstChild("Head")
                    or entity:FindFirstChild("Torso")
                    or entity.PrimaryPart
                    or (entity:IsA("Model") and entity:FindFirstChildWhichIsA("BasePart"))
                if not targetPart then
                    stopViewMode()
                    return
                end
            end

            -- Smooth follow behind/above entity
            local desiredCF = CFrame.new(
                targetPart.Position + Vector3.new(0, 8, 16),
                targetPart.Position
            )
            Camera.CFrame = Camera.CFrame:Lerp(desiredCF, 0.15)
        end)
    end)

    print("[Entity Scanner] Now viewing: " .. entity.Name)
end

