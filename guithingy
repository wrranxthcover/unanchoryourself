local function matchesEntityPattern(name)
    -- Match: 1-3 chars (letters or ï) + dash + number 1-2000
    -- ï is UTF-8 bytes: 0xC3 0xAF (Ã¯ in raw)
    
    local prefix, num = nil, nil
    
    -- Try to split at the LAST dash before numbers
    local dashPos = name:find("%-(%d+)$")
    if not dashPos then return false end
    
    prefix = name:sub(1, dashPos - 1)
    num = tonumber(name:sub(dashPos + 1))
    
    if not num or num < 1 or num > 2000 then return false end
    
    -- Count actual characters in prefix (ï is 2 bytes in UTF-8)
    -- Replace all ï (0xC3 0xAF) with single placeholder, then check length
    local cleaned = prefix:gsub("\195\175", "X") -- replace ï with X
    cleaned = cleaned:gsub("\195\143", "X")       -- replace Ï with X
    
    -- Must be 1-3 characters, all letters (after replacing ï)
    if #cleaned < 1 or #cleaned > 3 then return false end
    if not cleaned:match("^[A-Za-zX]+$") then return false end
    
    -- Original must only contain: A-Z, a-z, or ï bytes
    local valid = prefix:gsub("\195\175", ""):gsub("\195\143", "") -- remove all ï/Ï
    if not valid:match("^[A-Za-z]*$") then return false end
    
    return true
end
