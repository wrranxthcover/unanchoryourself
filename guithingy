local function track(entity)
    if tracked[entity] then return end
    if not entity.Parent then return end
    if isBlacklisted(entity.Name) then return end

    local color = getEntityColor(entity.Name)
    local d = {}

    local canHighlight = entity:IsA("Model") or entity:IsA("BasePart")
    if canHighlight then
        local hl = Instance.new("Highlight")
        hl.Adornee = entity; hl.FillColor = color; hl.FillTransparency = 0.55
        hl.OutlineColor = color; hl.OutlineTransparency = 0
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; hl.Enabled = espOn; hl.Parent = entity
        d.highlight = hl
    end

    local root = getEntityPart(entity)
    d.targetPart = root

    local function setupBillboard(part)
        if d.billboard or not part then return end
        local bb = Instance.new("BillboardGui")
        bb.Adornee = part; bb.Size = UDim2.new(0, 140, 0, 50)
