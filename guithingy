Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function(c) pChars[c] = true end)
    p.CharacterRemoving:Connect(function(c) pChars[c] = nil end)
end)
Players.PlayerRemoving:Connect(function(p) if p.Character then pChars[p.Character] = nil end end)

local function isEnt(obj)
    if pChars[obj] then return false end
    if bl[obj.Name] then return false end
    return matchPat(obj.Name)
end

local function getPart(obj)
    if obj:IsA("BasePart") then return obj end
    if obj:IsA("Model") then
        return obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
            or obj:FindFirstChild("Torso") or obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart", true)
    end
    return obj:FindFirstChildWhichIsA("BasePart", true)
end

