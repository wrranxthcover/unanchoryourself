-- ============================================
-- PATTERN: 1-3 letters, dash, 1-2000
-- A-1, AB-50, ABC-1000, Z-2000
-- ============================================

local function matchesEntityPattern(name)
    -- Must be: letters (1-3) + dash + number (1-2000)
    local letters, num = name:match("^([A-Za-z][A-Za-z]?[A-Za-z]?)%-(%d+)$")
    if not letters or not num then return false end
    local n = tonumber(num)
    return n and n >= 1 and n <= 2000
end

local function getEntityNumber(name)
    return tonumber(name:match("(%d+)$")) or 0
end

local function getEntityLetters(name)
    return name:match("^([A-Za-z]+)%-") or ""
end

-- Color from letters
local colorCache = {}
local function getEntityColor(name)
    if colorCache[name] then return colorCache[name] end
    local letters = getEntityLetters(name):upper()
    local hue = 0
    for i = 1, #letters do
        hue = hue + (string.byte(letters, i) - 65) * 14 + i * 53
    end
    local c = Color3.fromHSV((hue % 360) / 360, 0.85, 1)
    colorCache[name] = c
    return c
end

-- ============================================
-- PLAYER CHECK
-- ============================================

local playerChars = {}
local function refreshPlayerChars()
    playerChars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then playerChars[p.Character] = true end
    end
end
refreshPlayerChars()

for _, p in ipairs(Players:GetPlayers()) do
    p.CharacterAdded:Connect(function(c) playerChars[c] = true end)
    p.CharacterRemoving:Connect(function(c) playerChars[c] = nil end)
end
Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function(c) playerChars[c] = true end)
    p.CharacterRemoving:Connect(function(c) playerChars[c] = nil end)
end)
Players.PlayerRemoving:Connect(function(p)
    if p.Character then playerChars[p.Character] = nil end
end)

local function isEntity(obj)
    if not obj:IsA("Model") then return false end
    if playerChars[obj] then return false end
    return matchesEntityPattern(obj.Name)
end

