-- ========================================================
-- HEAVY TELEMETRY TICK (v11.1 FIX)
-- ========================================================
local function heavyUpdateTick()
    local char = LP.Character
    local myR = char and char:FindFirstChild("HumanoidRootPart")
    if not myR then return end
    local myP = myR.Position
    local now = tick()

    local nearestDist = math.huge
    local nearestName = "NULL"
    local highestThreat = "SAFE"

    for ent, d in pairs(tracked) do
        local tp = d.targetPart
        if tp and tp.Parent then
            local rawDist = (myP - tp.Position).Magnitude
            local dist = math.floor(rawDist)
            local threat = d.threat

            if rawDist < nearestDist then 
                nearestDist = rawDist 
                nearestName = d.displayName
            end
            
            if threat == "LETHAL" or threat == "CRITICAL" or threat == "DANGER" then
                highestThreat = threat
                
                local nameKey = d.displayName
                local alert = activeNotifications[nameKey]
                if alert then
                    local zoneName, zoneColor = getProximityZone(rawDist)
                    setText(alert.DistanceLabel, "RANGE: " .. dist .. " STUDS [" .. zoneName .. "]")
                    setTextColor(alert.DistanceLabel, zoneColor)
                end
                
                if autoDefenseOn and rawDist < 100 then
                    executeAutoDefend()
                end
            end

            if d.entryDist then 
                local zoneName, zoneColor = getProximityZone(rawDist)
                setText(d.entryDist, dist .. " STUDS [" .. zoneName .. "]")
                setTextColor(d.entryDist, zoneColor)
            end

            local sd = spd[ent]
            if sd then
                local dt = now - sd.lT
                if dt >= 0.05 then
                    local s = (tp.Position - sd.lP).Magnitude / dt
                    sd.lP = tp.Position
                    sd.lT = now
                    sd.sp = s
                    
                    local approachTxt = "VECTOR: STATIC"
                    if s > FAST_THRESH then
                        approachTxt = "WARN: FAST VECTOR " .. math.floor(s) .. "m/s"
                    elseif s > SLOW_THRESH then
                        approachTxt = "WARN: MOVEMENT SIGNAL"
                    end
                    
                    if d.entrySpeed then 
                        setText(d.entrySpeed, approachTxt)
                    end
                end
            end
        end
    end

    local closet, closetDist = findNearestSafeClosetOptimized()
    if closetDist < math.huge then
        setText(ehLockerBtn, "TELEPORT LOCKER\nDIST: " .. math.floor(closetDist) .. " STUDS")
    else
        setText(ehLockerBtn, "TELEPORT LOCKER\nDIST: ---")
    end
    
    local nearestTableDist = math.huge
    for _, item in ipairs(safeSpots.Tables) do
        if item.Instance and item.Instance.Parent then
            local d = (myP - item.Primary.Position).Magnitude
            if d < nearestTableDist then nearestTableDist = d end
            if curTab == "safezones" and curHideSubTab == "tables" and item.UI then
                local zoneName, zoneColor = getProximityZone(d)
                setText(item.UI.DistLabel, math.floor(d) .. " STUDS [" .. zoneName .. "]")
                setTextColor(item.UI.DistLabel, zoneColor)
            end
        end
    end
    
    if curTab == "safezones" and curHideSubTab == "lockers" then
        for _, item in ipairs(safeSpots.Lockers) do
            if item.Instance and item.Instance.Parent and item.UI then
                local d = (myP - item.Primary.Position).Magnitude
                local zoneName, zoneColor = getProximityZone(d)
                setText(item.UI.DistLabel, math.floor(d) .. " STUDS [" .. zoneName .. "]")
                setTextColor(item.UI.DistLabel, zoneColor)
            end
        end
    end

    if nearestTableDist < math.huge then
        setText(ehTableBtn, "TELEPORT TABLE\nDIST: " .. math.floor(nearestTableDist) .. " STUDS")
    else
        setText(ehTableBtn, "TELEPORT TABLE\nDIST: ---")
    end

    setText(timeL, "SYS_T: " .. formatTime(now - sessionStart))
    setText(statL, "DET: " .. totalDetected .. " | ALERTS: " .. totalAlerts)
    
    if nearestDist < math.huge then
        local zoneName, zoneColor = getProximityZone(nearestDist)
        setText(nearL, "PROX_DIST: " .. nearestName .. " [" .. math.floor(nearestDist) .. "s] :: " .. zoneName)
        setTextColor(nearL, zoneColor)
    else
        setText(nearL, "PROX_DIST: NULL")
        setTextColor(nearL, COLOR_TEXT_MUTED)
    end
    
    setText(threatL, "STATUS: " .. highestThreat)
    setTextColor(threatL, getThreatCol(highestThreat))
end

