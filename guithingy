    indicator.Name = "ViewIndicator"
    indicator.ResetOnSpawn = false
    indicator.DisplayOrder = 100
    indicator.Parent = LocalPlayer.PlayerGui

    local arrow = Instance.new("TextLabel")
    arrow.Name = "Arrow"
    arrow.Size = UDim2.new(0, 160, 0, 50)
    arrow.AnchorPoint = Vector2.new(0.5, 0)
    arrow.Position = UDim2.new(0.5, 0, 0, 8)
    arrow.BackgroundColor3 = Color3.fromRGB(15, 0, 35)
    arrow.BackgroundTransparency = 0.2
    arrow.Text = "⚠ " .. entity.Name .. "\n? studs"
    arrow.TextColor3 = getEntityColor(entity.Name)
    arrow.TextSize = 13
    arrow.Font = Enum.Font.GothamBold
    arrow.TextStrokeTransparency = 0.3
    arrow.TextStrokeColor3 = Color3.new(0, 0, 0)
    arrow.Parent = indicator
    Instance.new("UICorner", arrow).CornerRadius = UDim.new(0, 6)

    local arrowStroke = Instance.new("UIStroke")
    arrowStroke.Color = getEntityColor(entity.Name)
    arrowStroke.Thickness = 1.5
    arrowStroke.Transparency = 0.3
    arrowStroke.Parent = arrow

    viewIndicator = indicator

    local frameSkip = 0
    viewConn = RunService.Heartbeat:Connect(function()
        if not viewing or not entity or not entity.Parent then
            stopView()
            return
        end

        if not root or not root.Parent then
            root = getEntityPart(entity)
            data.targetPart = root
            if not root then stopView(); return end
        end

        frameSkip += 1
        if frameSkip < 3 then return end
        frameSkip = 0

        local screenPos, onScreen = Camera:WorldToScreenPoint(root.Position)
        local vp = Camera.ViewportSize

        local char = LocalPlayer.Character
        local myRoot = char and char:FindFirstChild("HumanoidRootPart")
        local distText = "?"
        if myRoot then
            distText = math.floor((myRoot.Position - root.Position).Magnitude) .. " studs"
        end

        arrow.Text = "⚠ " .. entity.Name .. "\n" .. distText

        if onScreen then
            local sx = math.clamp(screenPos.X, 80, vp.X - 80)
            local sy = math.clamp(screenPos.Y, 8, 60)
            arrow.Position = UDim2.new(0, sx, 0, sy)
        else
            local dir = (root.Position - Camera.CFrame.Position).Unit
            local camRight = Camera.CFrame.RightVector
            local dot2 = camRight:Dot(dir)
            arrow.Position = UDim2.new(dot2 > 0 and 1 or 0, dot2 > 0 and -90 or 10, 0, 8)
        end
    end)
end

-- ============================================
-- TRACK / UNTRACK
-- ============================================

local function untrack(entity)
    local d = tracked[entity]
    if not d then return end
    pcall(function() if d.highlight then d.highlight:Destroy() end end)
    pcall(function() if d.billboard then d.billboard:Destroy() end end)
    if d.destroyConn then d.destroyConn:Disconnect() end
    if d.childConn then d.childConn:Disconnect() end
    pcall(function() if d.entry then d.entry:Destroy() end end)
    tracked[entity] = nil
    entCount = math.max(0, entCount - 1)
    CL.Text = "Entities: " .. entCount
    CL.TextColor3 = entCount > 0 and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(255, 190, 40)
    EL.Visible = entCount == 0
    if viewTarget == entity then stopView() end
    if viewEntityTarget == entity then stopViewEntity() end
end

local function track(entity)
    if tracked[entity] then return end
    if not entity.Parent then return end

    local color = getEntityColor(entity.Name)
    local d = {}

    local canHighlight = entity:IsA("Model") or entity:IsA("BasePart")
    if canHighlight then
        local hl = Instance.new("Highlight")
        hl.Adornee = entity
        hl.FillColor = color
        hl.FillTransparency = 0.55
        hl.OutlineColor = color
        hl.OutlineTransparency = 0
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Enabled = espOn
        hl.Parent = entity
        d.highlight = hl
    end

    local root = getEntityPart(entity)
    d.targetPart = root

    local function setupBillboard(part)
        if d.billboard then return end
        if not part then return end

        local bb = Instance.new("BillboardGui")
        bb.Adornee = part
