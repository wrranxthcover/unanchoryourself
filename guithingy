local function mb(parent, text, color, posXScale, sizeXScale)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(sizeXScale, -4, 1, 0)
    btn.Position = UDim2.new(posXScale, 2, 0, 0)
    btn.BackgroundColor3 = Color3.fromRGB(25, 27, 34)
    btn.BorderSizePixel = 0
    btn.Text = text:upper()
    btn.TextColor3 = Color3.fromRGB(200, 205, 210)
    btn.TextSize = 8
    btn.Font = Enum.Font.Code
    btn.Parent = parent
    
    local bs = Instance.new("UIStroke")
    bs.Color = COLOR_BORDER
    bs.Thickness = 1
    bs.Parent = btn
    
    local line = Instance.new("Frame")
    line.Size = UDim2.new(1, 0, 0, 1)
    line.Position = UDim2.new(0, 0, 1, -1)
    line.BackgroundColor3 = color
    line.BorderSizePixel = 0
    line.Parent = btn
    
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 2)
    
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(35, 38, 48)
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(25, 27, 34)
    end)
    
    return btn
end

