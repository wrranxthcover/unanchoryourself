local function clearLeftStack()
    for _, f in pairs(leftEntries) do pcall(function() f:Destroy() end) end
    leftEntries = {}
end

local function updateLeftStack(redList, closestName)
    for name, frame in pairs(leftEntries) do
        if not redList[name] or name == closestName then
            pcall(function() frame:Destroy() end)
            leftEntries[name] = nil
        end
    end

    local count = 0
    for name, _ in pairs(redList) do if name ~= closestName then count += 1 end end

    local eh = count <= 3 and 32 or count <= 6 and 26 or count <= 10 and 22 or 18
    local fs = count <= 3 and 13 or count <= 6 and 11 or count <= 10 and 9 or 8

    for name, dist in pairs(redList) do
        if name == closestName then continue end
        if leftEntries[name] then
            local f = leftEntries[name]
            f.Size = UDim2.new(1, 0, 0, eh)
            local dl = f:FindFirstChild("DL"); if dl then dl.Text = dist .. "s" end
            local nl = f:FindFirstChild("NL"); if nl then nl.TextSize = fs end
            f.LayoutOrder = dist
        else
            local f = Instance.new("Frame")
            f.Size = UDim2.new(1, 0, 0, eh); f.BackgroundColor3 = Color3.fromRGB(100, 0, 0)
            f.BackgroundTransparency = 0.15; f.BorderSizePixel = 0; f.LayoutOrder = dist; f.Parent = LeftStack
            Instance.new("UICorner", f).CornerRadius = UDim.new(0, 5)
            local ls = Instance.new("UIStroke"); ls.Color = Color3.fromRGB(255, 40, 40); ls.Thickness = 1; ls.Transparency = 0.3; ls.Parent = f

            local icon = Instance.new("TextLabel")
            icon.Size = UDim2.new(0, 20, 1, 0); icon.Position = UDim2.new(0, 3, 0, 0)
            icon.BackgroundTransparency = 1; icon.Text = "⚠"; icon.TextColor3 = Color3.fromRGB(255, 60, 60)
            icon.TextSize = fs; icon.Font = Enum.Font.GothamBold; icon.Parent = f

            local nl = Instance.new("TextLabel"); nl.Name = "NL"
            nl.Size = UDim2.new(0.55, -20, 1, 0); nl.Position = UDim2.new(0, 22, 0, 0)
            nl.BackgroundTransparency = 1; nl.Text = name; nl.TextColor3 = Color3.fromRGB(255, 200, 200)
            nl.TextSize = fs; nl.Font = Enum.Font.GothamBold; nl.TextXAlignment = Enum.TextXAlignment.Left
            nl.TextTruncate = Enum.TextTruncate.AtEnd; nl.TextStrokeTransparency = 0.3; nl.Parent = f

            local dl = Instance.new("TextLabel"); dl.Name = "DL"
            dl.Size = UDim2.new(0.3, 0, 1, 0); dl.Position = UDim2.new(0.55, 0, 0, 0)
            dl.BackgroundTransparency = 1; dl.Text = dist .. "s"; dl.TextColor3 = Color3.fromRGB(255, 100, 100)
            dl.TextSize = fs - 1; dl.Font = Enum.Font.GothamSemibold; dl.TextXAlignment = Enum.TextXAlignment.Right; dl.Parent = f

            -- Speed label on left stack
            local sl = Instance.new("TextLabel"); sl.Name = "SL"
            sl.Size = UDim2.new(0.15, 0, 1, 0); sl.Position = UDim2.new(0.85, 0, 0, 0)
            sl.BackgroundTransparency = 1; sl.Text = ""; sl.TextColor3 = Color3.fromRGB(255, 255, 100)
            sl.TextSize = fs - 2; sl.Font = Enum.Font.GothamBold; sl.Parent = f

            leftEntries[name] = f
        end
    end
end

local function showAlert(entityName, dist, allRed, speedText)
    if alertActive and alertEntity == entityName then
        AlertDist.Text = dist .. "s away"
        AlertSpeed.Text = speedText or ""
        updateLeftStack(allRed, entityName)
        return
    end

    alertEntity = entityName
    AlertName.Text = "⚠ " .. entityName
    AlertDist.Text = dist .. "s away"
    AlertSpeed.Text = speedText or ""

    if not alertActive then
        AlertFrame.Size = UDim2.new(0, 0, 0, 80)
        AlertFrame.Visible = true
        alertActive = true
        TweenService:Create(AlertFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 500, 0, 80)
        }):Play()
    end
    alertActive = true

    if alertScrollConn then alertScrollConn:Disconnect() end
    local scrollX = 0
    local textWidth = 500
    alertScrollConn = RunService.Heartbeat:Connect(function(dt)
        if not alertActive then return end
        scrollX = scrollX - dt * 150
        if scrollX < -textWidth then scrollX = scrollX + textWidth end
        AlertHide.Position = UDim2.new(0, scrollX, 0, 0)
        AlertHide2.Position = UDim2.new(0, scrollX + textWidth, 0, 0)
    end)

    if alertPulseConn then alertPulseConn:Disconnect() end
    alertPulseConn = RunService.Heartbeat:Connect(function()
        if not alertActive then return end
        local p = (math.sin(tick() * 8) + 1) / 2
        AlertStroke.Color = Color3.fromRGB(math.floor(180 + 75 * p), 0, 0)
        AlertFrame.BackgroundColor3 = Color3.fromRGB(math.floor(80 + 60 * p), 0, 0)
    end)

    updateLeftStack(allRed, entityName)
end

local function hideAlert()
    if not alertActive then return end
    alertActive = false; alertEntity = nil
    TweenService:Create(AlertFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 80)
    }):Play()
    task.delay(0.3, function() if not alertActive then AlertFrame.Visible = false end end)
    if alertScrollConn then alertScrollConn:Disconnect(); alertScrollConn = nil end
    if alertPulseConn then alertPulseConn:Disconnect(); alertPulseConn = nil end
    clearLeftStack()
end

