local function clearLeftStack()
    for _, f in pairs(leftEntries) do pcall(function() f:Destroy() end) end; leftEntries = {}
end

local function updateLeftStack(redList, closest)
    for n, f in pairs(leftEntries) do
        if not redList[n] or n == closest then pcall(function() f:Destroy() end); leftEntries[n] = nil end
    end
    local cnt = 0; for n, _ in pairs(redList) do if n ~= closest then cnt += 1 end end
    local eh = cnt <= 3 and 28 or cnt <= 6 and 24 or cnt <= 10 and 20 or 16
    local fz = cnt <= 3 and 11 or cnt <= 6 and 10 or cnt <= 10 and 8 or 7
    for n, dist in pairs(redList) do
        if n == closest then continue end
        if leftEntries[n] then
            leftEntries[n].Size = UDim2.new(1, 0, 0, eh); leftEntries[n].LayoutOrder = dist
            local dl = leftEntries[n]:FindFirstChild("DL"); if dl then dl.Text = dist .. "s" end
        else
            local f = Instance.new("Frame"); f.Size = UDim2.new(1, 0, 0, eh); f.BackgroundColor3 = Color3.fromRGB(100, 0, 0)
            f.BackgroundTransparency = 0.15; f.BorderSizePixel = 0; f.LayoutOrder = dist; f.Parent = LeftStack
            Instance.new("UICorner", f).CornerRadius = UDim.new(0, 4)
            Instance.new("UIStroke", f).Color = Color3.fromRGB(255, 40, 40)
            local nl = Instance.new("TextLabel"); nl.Size = UDim2.new(0.6, -5, 1, 0); nl.Position = UDim2.new(0, 5, 0, 0)
            nl.BackgroundTransparency = 1; nl.Text = "⚠ " .. n; nl.TextColor3 = Color3.fromRGB(255, 200, 200)
            nl.TextSize = fz; nl.Font = Enum.Font.GothamBold; nl.TextXAlignment = Enum.TextXAlignment.Left
            nl.TextTruncate = Enum.TextTruncate.AtEnd; nl.TextStrokeTransparency = 0.3; nl.Parent = f
            local dl = Instance.new("TextLabel"); dl.Name = "DL"; dl.Size = UDim2.new(0.4, -5, 1, 0); dl.Position = UDim2.new(0.6, 0, 0, 0)
            dl.BackgroundTransparency = 1; dl.Text = dist .. "s"; dl.TextColor3 = Color3.fromRGB(255, 100, 100)
            dl.TextSize = fz; dl.Font = Enum.Font.GothamSemibold; dl.TextXAlignment = Enum.TextXAlignment.Right; dl.Parent = f
            leftEntries[n] = f
        end
    end
end

