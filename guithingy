-- ============================================
-- ENTITY PATTERN DETECTION
-- ============================================

-- Pattern: 1-3 uppercase/lowercase letters, dash, number 1-1000
-- Examples: A-1, B-500, AB-99, XYZ-1000, a-50, Ab-200
local function matchesEntityPattern(name)
    -- Match: 1-3 letters, dash, digits
    local letters, number = name:match("^([A-Za-z][A-Za-z]?[A-Za-z]?)%-(%d+)$")
    
    if letters and number then
        local num = tonumber(number)
        if num and num >= 1 and num <= 1000 then
            return true
        end
    end
    
    return false
end

-- Color based on letter prefix (hashed to hue)
local function getEntityColor(name)
    local prefix = name:match("^([A-Za-z]+)%-")
    if not prefix then return Color3.fromRGB(255, 80, 80) end
    
    prefix = prefix:upper()
    
    -- Simple hash: each letter adds to hue
    local hue = 0
    for i = 1, #prefix do
        local charVal = string.byte(prefix, i) - 65 -- A=0, B=1, ..., Z=25
        hue = hue + (charVal * (360 / 26)) + (i * 47)
    end
    hue = hue % 360
    
    return Color3.fromHSV(hue / 360, 0.9, 1)
end

-- Get the number from entity name for sorting
local function getEntityNumber(name)
    local num = name:match("%-(%d+)$")
    return tonumber(num) or 0
end

-- ============================================
-- BLACKLIST
-- ============================================

local BLACKLIST_WORDS = {
    "door", "room", "wall", "floor", "ceiling", "baseplate", "spawn",
    "lobby", "map", "light", "lamp", "prop", "furniture", "chair",
    "table", "shelf", "cabinet", "bed", "chest", "barrel", "box",
    "crate", "plant", "vent", "locker", "mirror", "couch", "sofa",
    "painting", "picture", "decoration", "handle", "knob", "frame",
    "panel", "button", "key", "lock", "sign", "poster", "tile",
    "carpet", "rug", "curtain", "radiator", "pipe", "wire", "cable",
    "switch", "outlet", "grate", "ladder", "stair", "railing",
    "pillar", "column", "arch", "shop", "merchant", "vendor", "item",
    "coin", "gold", "loot", "pickup", "badge", "checkpoint",
    "elevator", "lift", "generator", "lever", "valve", "window",
    "player", "character", "npc", "dummy",
}

local function isBlacklisted(name)
    local lower = name:lower()
    for _, word in ipairs(BLACKLIST_WORDS) do
        if lower:find(word) then return true end
    end
    return false
end

local function isPlayerCharacter(model)
    for _, player in pairs(Players:GetPlayers()) do
        if player.Character == model then return true end
    end
    return false
end

-- ============================================
-- CORE ENTITY CHECK
-- ============================================

local function isEntity(obj)
    if not obj:IsA("Model") then return false end
    if isPlayerCharacter(obj) then return false end
    if isBlacklisted(obj.Name) then return false end
    if matchesEntityPattern(obj.Name) then return true end
    return false
end

-- ============================================
-- SCAN WORKSPACE
-- ============================================

local function scanForEntities()
    local found = {}
    local seen = {}
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if not seen[obj] and isEntity(obj) then
            seen[obj] = true
            table.insert(found, obj)
        end
    end
    
    -- Sort by letter then number (A-1 before A-2 before B-1)
    table.sort(found, function(a, b)
        local prefixA = a.Name:match("^([A-Za-z]+)%-") or ""
        local prefixB = b.Name:match("^([A-Za-z]+)%-") or ""
        if prefixA:upper() == prefixB:upper() then
            return getEntityNumber(a.Name) < getEntityNumber(b.Name)
        end
        return prefixA:upper() < prefixB:upper()
    end)
    
    return found
end

