end

stopViewEntity = function()
    viewingEntity = false
    if viewEntityConn then viewEntityConn:Disconnect(); viewEntityConn = nil end
    if savedCameraType then Camera.CameraType = savedCameraType; savedCameraType = nil
    else Camera.CameraType = Enum.CameraType.Custom end
    local c = LP.Character; if c then local h = c:FindFirstChild("Head"); if h then Camera.CFrame = CFrame.new(h.Position + Vector3.new(0, 2, 8), h.Position) end end
    VEP.Visible = false; VEBtn.Text = "🎥 View Entity: OFF"; VEBtn.BackgroundColor3 = Color3.fromRGB(30, 60, 30)
