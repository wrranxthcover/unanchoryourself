-- Auto Door Opener - Walks near door and presses F
task.spawn(function()
    while task.wait(0.5) do
        if autoDoorOn then
            pcall(function()
                local prompt, dist = findNearestPrompt()
                if prompt and dist < 15 then
                    -- Boost prompt range
                    prompt.HoldDuration = 0
                    prompt.MaxActivationDistance = 20

                    -- Trigger it
                    pcall(function()
                        prompt:InputHoldBegin()
                        task.wait(0.1)
                        prompt:InputHoldEnd()
                    end)

                    -- Also press F
                    pcall(function()
                        VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game)
                        task.wait(0.1)
                        VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game)
                    end)

                    -- Also fire remotes related to doors
                    pcall(function()
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("ClickDetector") then
                                local p = v.Parent
                                if p and p:IsA("BasePart") then
                                    local hrp = getHRP()
                                    if hrp and (p.Position - hrp.Position).Magnitude < 15 then
                                        fireclickdetector(v)
                                    end
                                end
                            end
                        end
                    end)
                end
            end)
        end
    end
end)

