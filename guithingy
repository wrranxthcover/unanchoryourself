    viewBtn.MouseLeave:Connect(function()
        if currentlyViewing ~= entity then
            TweenService:Create(viewBtn, TweenInfo.new(0.15), {
                BackgroundColor3 = Color3.fromRGB(80, 0, 180)
            }):Play()
        end
    end)

    -- View button click
    viewBtn.MouseButton1Click:Connect(function()
        if currentlyViewing == entity then
            -- Toggle off
            stopViewMode()
            viewBtn.Text = "👁 View"
            viewBtn.BackgroundColor3 = Color3.fromRGB(80, 0, 180)
        else
            -- Stop current view first
            if currentlyViewing then
                -- Reset old button
                for ent, frame in pairs(entryMap) do
                    if ent == currentlyViewing then
                        local oldBtn = frame:FindFirstChild("ViewBtn")
                        if oldBtn then
                            oldBtn.Text = "👁 View"
                            oldBtn.BackgroundColor3 = Color3.fromRGB(80, 0, 180)
                        end
                    end
                end
            end

            -- Start new view
            startViewMode(entity)
            viewBtn.Text = "✔ Viewing"
            viewBtn.BackgroundColor3 = Color3.fromRGB(160, 0, 255)
        end
    end)

    entryMap[entity] = entry
    return entry
end

-- ============================================
-- SCANNER + DISTANCE UPDATE
-- ============================================

local function scanForEntities()
    local foundEntities = {}
    local containers = getEntityContainers()
    for _, container in pairs(containers) do
        if container then
            for _, descendant in pairs(container:GetDescendants()) do
                if descendant:IsA("Model") and isEntity(descendant) then
                    table.insert(foundEntities, descendant)
                end
            end
        end
    end
    return foundEntities
end

local function updateScanner()
    if not scannerActive then return end
    local entities = scanForEntities()
    local currentEntitySet = {}

    for _, entity in pairs(entities) do
        currentEntitySet[entity] = true
        if not entityESPObjects[entity] then
            createESP(entity)
            local color = getEntityColor(entity.Name)
            createEntityListEntry(entity, color)
        end
    end

    for entity, _ in pairs(entityESPObjects) do
        if not currentEntitySet[entity] or not entity.Parent then
            removeESP(entity)
            removeEntityListEntry(entity)
        end
    end

    local count = 0
    for _ in pairs(entityESPObjects) do count = count + 1 end
    EntityCountLabel.Text = "Entities Detected: " .. tostring(count)

    if count > 0 then
        EntityCountLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    else
        EntityCountLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
    end
end

local function updateDistances()
    local character = LocalPlayer.Character
    if not character then return end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    for entity, data in pairs(entityESPObjects) do
        local targetPart = data.targetPart
        if not targetPart then
            -- Try to re-find it
            targetPart = entity:FindFirstChild("HumanoidRootPart")
                or entity:FindFirstChild("Head")
                or entity:FindFirstChild("Torso")
                or entity.PrimaryPart
                or (entity:IsA("Model") and entity:FindFirstChildWhichIsA("BasePart"))
            data.targetPart = targetPart
        end

        if targetPart and targetPart.Parent then
            local dist = math.floor((rootPart.Position - targetPart.Position).Magnitude)

            -- Update billboard dist
            if data.distLabel then
                data.distLabel.Text = tostring(dist) .. " studs"
                if dist < 25 then
                    data.distLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
                elseif dist < 60 then
                    data.distLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
                else
                    data.distLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
                end
            end

            -- Update list entry distance
            local entryFrame = entryMap[entity]
            if entryFrame then
                local distLabel = entryFrame:FindFirstChild("Distance")
                if distLabel then
                    distLabel.Text = tostring(dist) .. " studs away"
                    if dist < 25 then
                        distLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
                    elseif dist < 60 then
                        distLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
                    else
                        distLabel.TextColor3 = Color3.fromRGB(130, 130, 150)
                    end
                end
            end
        end
    end
end

