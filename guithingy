ViewTopBtn.MouseButton1Click:Connect(function()
    if viewModeActive then
        stopViewMode()
        return
    end
    -- Find nearest
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local nearest, nearDist = nil, math.huge
    for entity, data in pairs(entityESPObjects) do
        local tp = data.targetPart
        if tp and tp.Parent then
            local d = (root.Position - tp.Position).Magnitude
            if d < nearDist then nearest = entity; nearDist = d end
        end
    end

    if nearest then
        startViewMode(nearest)
        local ef = entryMap[nearest]
        if ef then
            local btn = ef:FindFirstChild("ViewBtn")
            if btn then btn.Text = "✔ On"; btn.BackgroundColor3 = Color3.fromRGB(150, 0, 255) end
        end
    else
        ViewTopBtn.Text = "None Found!"
        ViewTopBtn.BackgroundColor3 = Color3.fromRGB(160, 30, 30)
        task.delay(1.5, function()
            ViewTopBtn.Text = "👁 View"
            ViewTopBtn.BackgroundColor3 = Color3.fromRGB(90, 0, 190)
        end)
    end
end)

