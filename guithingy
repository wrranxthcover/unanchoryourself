-- // ===== CORE FUNCTIONS ===== //

local function getCharacter()
    return player.Character or player.CharacterAdded:Wait()
end

local function getHRP()
    local char = getCharacter()
    return char and char:FindFirstChild("HumanoidRootPart")
end

-- UNANCHOR
local function unanchor()
    local character = getCharacter()
    local count = 0

    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.Anchored then
            part.Anchored = false
            count = count + 1
        end
    end

    if character:FindFirstChild("Humanoid") then
        character.Humanoid:ChangeState(Enum.HumanoidStateType.Running)
    end

    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.Velocity = Vector3.new(0, 10, 0)
    end

    if count > 0 then
        statusLabel.Text = "Status: ✅ Unanchored " .. count .. " parts!"
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
    else
        statusLabel.Text = "Status: ⚠️ Already unanchored"
        statusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    end

    -- Flash
    unanchorBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
    tweenService:Create(unanchorBtn, TweenInfo.new(0.5), {
        BackgroundColor3 = Color3.fromRGB(0, 100, 255)
    }):Play()
end

-- FIND NEAREST DOOR PROMPT
local function findNearestPrompt()
    local hrp = getHRP()
    if not hrp then return nil end

    local closest = nil
    local closestDist = math.huge

    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.Enabled then
            local parent = v.Parent
            if parent and parent:IsA("BasePart") then
                local dist = (parent.Position - hrp.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = v
                end
            elseif parent and parent:FindFirstChildWhichIsA("BasePart") then
                local part = parent:FindFirstChildWhichIsA("BasePart")
                local dist = (part.Position - hrp.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = v
                end
            end
        end
    end

    return closest, closestDist
end

-- FORCE TRIGGER PROMPT (simulates F key press)
local function forceInteract()
    local prompt, dist = findNearestPrompt()

    if prompt then
        -- Method 1: Fire the prompt directly
        pcall(function()
            prompt:InputHoldBegin()
            task.wait(prompt.HoldDuration + 0.1)
            prompt:InputHoldEnd()
        end)

        -- Method 2: Fire all click detectors too
        pcall(function()
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("ClickDetector") then
                    local part = v.Parent
                    if part and part:IsA("BasePart") then
                        local hrp = getHRP()
                        if hrp and (part.Position - hrp.Position).Magnitude < 15 then
                            fireclickdetector(v)
                        end
                    end
                end
            end
        end)

        -- Method 3: Simulate F keypress
        pcall(function()
            VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game)
            task.wait(0.1)
            VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game)
        end)

        statusLabel.Text = "Status: 🚪 Opened door! (Dist: " .. math.floor(dist) .. ")"
        statusLabel.TextColor3 = Color3.fromRGB(0, 200, 255)
    else
        -- Just press F anyway
        pcall(function()
            VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game)
            task.wait(0.15)
            VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game)
        end)

        statusLabel.Text = "Status: ❌ No door found nearby"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end

