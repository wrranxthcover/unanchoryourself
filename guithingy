local function updateRadar(dt)
    if not radarOn then radarFrame.Visible = false; return end
    radarFrame.Visible = true
    local char = LP.Character; local mr = char and char:FindFirstChild("HumanoidRootPart")
    if not mr then return end
    local myP = mr.Position; local camCF = Camera.CFrame
    
    local forward = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z)
    if forward.Magnitude > 0.01 then forward = forward.Unit else forward = Vector3.new(0,0,-1) end
    
    local rightVec = Vector3.new(camCF.RightVector.X, 0, camCF.RightVector.Z)
    if rightVec.Magnitude > 0.01 then rightVec = rightVec.Unit else rightVec = Vector3.new(1,0,0) end

    sweepAngle = sweepAngle + (240 * (dt or RADAR_UPDATE_INTERVAL))
    if sweepAngle >= 360 then sweepAngle = sweepAngle % 360 end
    sweepLine.Rotation = sweepAngle

    for name, dot in pairs(radarDots) do
        if not dot._entity or not tracked[dot._entity] or not tracked[dot._entity].targetPart then 
            pcall(function() dot:Destroy() end)
            radarDots[name] = nil 
        end
    end

    for ent, d in pairs(tracked) do
        local tp = d.targetPart
        if tp and tp.Parent then
            local offset = tp.Position - myP; local dist = offset.Magnitude
            if dist <= RADAR_RANGE and dist > 0.5 then
                local flatOff = Vector3.new(offset.X, 0, offset.Z)
                local relX = rightVec:Dot(flatOff) / RADAR_RANGE * 0.45
                local relY = -forward:Dot(flatOff) / RADAR_RANGE * 0.45
                local dotKey = tostring(ent)
                local dot = radarDots[dotKey]
                
                if not dot or not dot.Parent then
                    dot = Instance.new("Frame"); dot.Size = UDim2.new(0, 4, 0, 4); dot.AnchorPoint = Vector2.new(0.5, 0.5); dot.BorderSizePixel = 0; dot.ZIndex = 10; dot.Parent = radarFrame
                    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
                    dot._entity = ent; radarDots[dotKey] = dot
                end
                dot.Position = UDim2.new(0.5 + relX, 0, 0.5 + relY, 0)
                dot.BackgroundColor3 = d.threatCol or getThreatCol(d.threat or "UNKNOWN")
            end
        end
    end
    
    local dotCount = 0; for _ in pairs(radarDots) do dotCount += 1 end
    setText(radarTitle, "LIDAR RNG:" .. RADAR_RANGE .. " // ACT_SIG:" .. dotCount)
end

