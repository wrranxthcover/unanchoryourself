local function matchPat(name)
    local low = name:lower()
    
    if low:find("prompt") or low:find("trigger") or low:find("part") or low:find("interact") 
       or low:find("location") or low:find("marker") or low:find("zone") or low:find("node")
       or low:find("spawn") or low:find("despawn") or low:find("template") or low:find("fake") 
       or low:find("clone") or low:find("decoy") or low:find("dummy") or low:find("troll")
       or low:find("test") or low:find("mock") or low:find("fanmade") or low:find("visual")
       or low:find("model") or low:find("audio") or low:find("sound") or low:find("setup") then
        return false
    end
    
    if low == "hide" or low:find("^hide%d+") or low:find("hidepoint") or low:find("hidespot") or low:find("hideto") then
        return false
    end
    
    local cleanName = cleanSymbols(name)
    if KNOWN_ENTITIES[cleanName] then return true end
    
    local roomsLetter, roomsNum, roomsSuffix = low:match("^([a-z])%-?(%d+)([a-z]?)$")
    if roomsLetter and roomsNum then
        local num = tonumber(roomsNum)
        if num and num >= 1 and num <= 99999 then
            return true
        end
    end
    
    return false
end

