local espEnabled = true
local namesEnabled = true
local entityESPObjects = {} -- {model = {highlight, billboard, connection}}
local scannerActive = true

-- Entity color mapping
local ENTITY_COLORS = {
    -- Doors-style entities
    ["Rush"] = Color3.fromRGB(255, 0, 0),
    ["Ambush"] = Color3.fromRGB(255, 50, 0),
    ["Screech"] = Color3.fromRGB(200, 0, 200),
    ["Halt"] = Color3.fromRGB(255, 255, 0),
    ["Eyes"] = Color3.fromRGB(150, 0, 255),
    ["Seek"] = Color3.fromRGB(0, 0, 0),
    ["Figure"] = Color3.fromRGB(100, 0, 0),
    ["Glitch"] = Color3.fromRGB(0, 255, 100),
    ["Jack"] = Color3.fromRGB(255, 150, 0),
    ["Timothy"] = Color3.fromRGB(139, 90, 43),
    ["Shadow"] = Color3.fromRGB(50, 50, 50),
    ["Snare"] = Color3.fromRGB(0, 100, 0),
    ["Dupe"] = Color3.fromRGB(180, 0, 180),
    ["A-60"] = Color3.fromRGB(255, 30, 30),
    ["A-90"] = Color3.fromRGB(255, 60, 60),
    ["A-120"] = Color3.fromRGB(255, 90, 90),
    ["RushMoving"] = Color3.fromRGB(255, 0, 0),
    ["AmbushMoving"] = Color3.fromRGB(255, 50, 0),
    ["Default"] = Color3.fromRGB(255, 80, 80),
}

-- Known entity name patterns to detect
local ENTITY_PATTERNS = {
    "Rush", "Ambush", "Screech", "Halt", "Eyes", "Seek", "Figure",
    "Glitch", "Jack", "Timothy", "Shadow", "Snare", "Dupe",
    "A-60", "A-90", "A-120", "RushMoving", "AmbushMoving",
    "Entity", "Monster", "Creature", "Ghost", "Demon"
}

local function getEntityColor(name)
    for key, color in pairs(ENTITY_COLORS) do
        if string.find(name:lower(), key:lower()) then
            return color
        end
    end
    return ENTITY_COLORS["Default"]
end

local function isEntity(obj)
    local name = obj.Name:lower()

    -- Check against known patterns
    for _, pattern in ipairs(ENTITY_PATTERNS) do
        if string.find(name, pattern:lower()) then
            return true
        end
    end

    -- Check if it's a model with humanoid-like properties but not a player
    if obj:IsA("Model") then
        -- Not a player character
        for _, player in pairs(Players:GetPlayers()) do
            if player.Character == obj then
                return false
            end
        end

        -- Has a primary part or humanoidrootpart
        local hasPart = obj:FindFirstChild("HumanoidRootPart")
            or obj:FindFirstChild("Head")
            or obj:FindFirstChild("Torso")
            or obj.PrimaryPart

        -- Check various entity indicators
        if hasPart then
            -- Check if it has entity-like attributes
            local hasHumanoid = obj:FindFirstChildOfClass("Humanoid")
            local hasAnimController = obj:FindFirstChildOfClass("AnimationController")

            if hasHumanoid or hasAnimController then
                -- Make sure it's not a player
                local isPlayer = false
                for _, player in pairs(Players:GetPlayers()) do
                    if player.Character == obj then
                        isPlayer = true
                        break
                    end
                end
                if not isPlayer then
                    return true
                end
            end
        end
    end

    return false
end

-- Broader scan: check specific Rooms/Doors game folders
local function getEntityContainers()
    local containers = {}

    -- Common entity locations in Rooms/Doors-style games
    local possiblePaths = {
        workspace,
        workspace:FindFirstChild("Entities"),
        workspace:FindFirstChild("Entity"),
        workspace:FindFirstChild("Monsters"),
        workspace:FindFirstChild("CurrentRooms"),
        workspace:FindFirstChild("Rooms"),
        workspace:FindFirstChild("Map"),
    }

    for _, container in pairs(possiblePaths) do
        if container then
            table.insert(containers, container)
        end
    end

    return containers
end

local function createESP(entity)
    if entityESPObjects[entity] then return end

    local entityName = entity.Name
    local color = getEntityColor(entityName)

    local espData = {}

    -- Create Highlight
    if espEnabled then
        local highlight = Instance.new("Highlight")
        highlight.Name = "EntityESP"
        highlight.Adornee = entity
        highlight.FillColor = color
        highlight.FillTransparency = 0.7
        highlight.OutlineColor = color
        highlight.OutlineTransparency = 0.1
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = entity
        espData.highlight = highlight
    end

    -- Create Billboard for name
    if namesEnabled then
        local targetPart = entity:FindFirstChild("HumanoidRootPart")
            or entity:FindFirstChild("Head")
            or entity:FindFirstChild("Torso")
            or entity.PrimaryPart
            or (entity:IsA("Model") and entity:FindFirstChildWhichIsA("BasePart"))

        if targetPart then
            local billboard = Instance.new("BillboardGui")
            billboard.Name = "EntityNameESP"
            billboard.Adornee = targetPart
            billboard.Size = UDim2.new(0, 200, 0, 60)
            billboard.StudsOffset = Vector3.new(0, 4, 0)
            billboard.AlwaysOnTop = true
            billboard.MaxDistance = math.huge
            billboard.Parent = targetPart

            -- Entity Name Label
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = "⚠ " .. entityName
            nameLabel.TextColor3 = color
            nameLabel.TextSize = 18
            nameLabel.Font = Enum.Font.GothamBold
            nameLabel.TextStrokeTransparency = 0.3
            nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
            nameLabel.Parent = billboard

            -- Distance Label
            local distLabel = Instance.new("TextLabel")
            distLabel.Name = "DistLabel"
            distLabel.Size = UDim2.new(1, 0, 0.4, 0)
            distLabel.Position = UDim2.new(0, 0, 0.5, 0)
            distLabel.BackgroundTransparency = 1
            distLabel.Text = "0 studs"
            distLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
            distLabel.TextSize = 14
            distLabel.Font = Enum.Font.GothamSemibold
            distLabel.TextStrokeTransparency = 0.5
            distLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
            distLabel.Parent = billboard

            espData.billboard = billboard
            espData.distLabel = distLabel
            espData.targetPart = targetPart
        end
    end

    -- Track destruction
    espData.destroyConnection = entity.AncestryChanged:Connect(function(_, parent)
        if not parent then
            removeESP(entity)
        end
    end)

    entityESPObjects[entity] = espData
end

function removeESP(entity)
    local data = entityESPObjects[entity]
    if data then
        if data.highlight then
            data.highlight:Destroy()
        end
        if data.billboard then
            data.billboard:Destroy()
        end
        if data.destroyConnection then
            data.destroyConnection:Disconnect()
        end
        entityESPObjects[entity] = nil
    end
end

local function clearAllESP()
    for entity, _ in pairs(entityESPObjects) do
        removeESP(entity)
    end
    entityESPObjects = {}
end

