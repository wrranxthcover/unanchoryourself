local function cleanSymbols(str)
    local replacements = {
        ["\195\164"] = "a", ["\195\166"] = "ae", ["\195\182"] = "o", ["\195\188"] = "u",
        ["\195\175"] = "i", ["\195\171"] = "e", ["\195\191"] = "y", ["\195\165"] = "a",
        ["\195\184"] = "o", ["\194\175"] = "i", ["\195\143"] = "X", ["\195\145"] = "N",
    }
    for utf8Char, asciiRepl in pairs(replacements) do str = str:gsub(utf8Char, asciiRepl) end
    str = str:gsub("[%s%p%c%s]", "")
    str = str:gsub("[%z\1-\127]", function(c) return c:match("%w") and c or "" end)
    return str:lower()
end

local function matchPat(name)
    local lowName = name:lower()
    if (lowName:find("spawn") or lowName:find("template") or lowName:find("node") or lowName:find("trigger") 
    or lowName:find("config") or lowName:find("setup") or lowName:find("model") or lowName:find("folder") 
    or lowName:find("point") or lowName:find("marker") or lowName:find("part") or lowName:find("location")
    or lowName:find("ambient") or lowName:find("ambience") or lowName:find("sound") or lowName:find("theme")
    or lowName:find("door") or lowName:find("room") or lowName:find("frame") or lowName:find("button")) 
    and not lowName:find("clone") then
        return false
    end

    local cleanName = cleanSymbols(name)
    if KNOWN_ENTITIES[cleanName] then return true end
    
    local dp = name:find("%-(%d+)$")
    if dp then
        local pre = name:sub(1, dp-1)
        local num = tonumber(name:sub(dp+1))
        if num and num >= 1 and num <= 3000 then
            local cleanPre = cleanSymbols(pre)
            if #cleanPre >= 1 and #cleanPre <= 3 then return true end
        end
    end
    return false
end

local function isMinion(name) local l = name:lower(); return l == "eye" or l == "mouth" end

local function getDisplayName(entity)
    local l = entity.Name:lower()
    if l == "eye" or l == "mouth" then
        local parent = entity.Parent
        if parent then
            if matchPat(parent.Name) then return parent.Name .. "'s " .. entity.Name end
        end
    end
    return entity.Name
end

local function getPrefix(name)
    if name:match("^[Mm][Oo][Bb]%d+$") then return "MOB" end
    local l = name:lower()
    if KNOWN_ENTITIES[l] then return name end
    local dp = name:find("%-(%d+)$"); if not dp then return name end; return name:sub(1, dp-1)
end

local function getNum(name) return tonumber(name:match("(%d+)$")) or 0 end

local cCache = {}
local function getCol(name)
    if cCache[name] then return cCache[name] end
    local p = getPrefix(name); local h = 0
    for i = 1, #p do h = h + string.byte(p,i)*14 + i*53 end
    local c = Color3.fromHSV((h%360)/360, 0.85, 1); cCache[name] = c; return c
end

local function formatTime(s)
    local m = math.floor(s/60); local sec = math.floor(s%60)
    return string.format("%02d:%02d", m, sec)
end

