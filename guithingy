-- ============================================
-- DEBUG
-- ============================================

local function runDebug()
    print("========== ENTITY SCANNER DEBUG ==========")
    local found, nearMatch = 0, 0
    for _, obj in ipairs(workspace:GetDescendants()) do
        if matchesEntityPattern(obj.Name) then
            found += 1
            print(string.format("  ✅ MATCH: '%s' [%s] Path:%s", obj.Name, obj.ClassName, obj:GetFullName()))
        elseif obj.Name:match("%-%d") then
            nearMatch += 1
            if nearMatch <= 30 then
                local bytes = {}
                for i = 1, #obj.Name do
                    table.insert(bytes, string.format("%02X", string.byte(obj.Name, i)))
                end
                print(string.format("  ⚠ NEAR: '%s' [%s] Bytes:[%s]", obj.Name, obj.ClassName, table.concat(bytes, " ")))
            end
        end
    end
    print(string.format("Found: %d exact | %d near-matches", found, nearMatch))
    DLabel.Text = "🔎 Found: " .. found .. " exact | " .. nearMatch .. " near"
    DLabel.TextColor3 = found > 0 and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 80, 80)
end

