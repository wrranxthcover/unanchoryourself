-- PULSE ANIMATION
-- ============================================

local pulseDirection = 1
local pulsePos = 0

spawn(function()
    while scannerActive do
        pulsePos = pulsePos + (0.02 * pulseDirection)
        if pulsePos >= 0.7 then
            pulseDirection = -1
        elseif pulsePos <= 0 then
            pulseDirection = 1
        end
        PulseBar.Position = UDim2.new(pulsePos, 0, 1, -3)

        -- Pulse the scanner icon
        local alpha = (math.sin(tick() * 3) + 1) / 2
        ScannerIcon.TextTransparency = alpha * 0.5

        task.wait(0.03)
    end
end)

