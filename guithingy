-- FORCE SPEED (10 Methods - Every Frame)
-- ============================================
local speedApplyConn = nil
local speedApplyTarget = nil
local speedApplyActive = false

local function forceSpeed(target, speed)
    if not target or not target.Parent then return end
    local absSpeed = math.abs(speed)
    local reversed = speed < 0

    local allParts = {}
    if target:IsA("BasePart") then table.insert(allParts, target)
    else for _, desc in ipairs(target:GetDescendants()) do if desc:IsA("BasePart") then table.insert(allParts, desc) end end end
    if #allParts == 0 then return end

    local root = getPart(target); if not root then root = allParts[1] end

    -- FORCE 1: DESTROY all movers
    for _, child in ipairs(target:GetDescendants()) do pcall(function()
        if child:IsA("BodyVelocity") and child.Name ~= "SpeedControlBV" then child:Destroy() end
        if child:IsA("BodyForce") then child:Destroy() end
        if child:IsA("BodyPosition") then child:Destroy() end
        if child:IsA("BodyGyro") then child:Destroy() end
        if child:IsA("LinearVelocity") then child:Destroy() end
        if child:IsA("AlignPosition") then child:Destroy() end
        if child:IsA("AlignOrientation") then child:Destroy() end
        if child:IsA("VectorForce") then child:Destroy() end
        if child:IsA("LineForce") then child:Destroy() end
        if child:IsA("BodyThrust") then child:Destroy() end
        if child:IsA("RocketPropulsion") then child:Destroy() end
    end) end

    -- FORCE 2: Disable scripts
    for _, child in ipairs(target:GetDescendants()) do pcall(function()
        if child:IsA("Script") or child:IsA("LocalScript") then child.Disabled = true end
    end) end

    -- FORCE 3: Override values
    for _, child in ipairs(target:GetDescendants()) do pcall(function()
        if child:IsA("NumberValue") or child:IsA("IntValue") then
            local ln = child.Name:lower()
            if ln:find("speed") or ln:find("spd") or ln:find("velocity") or ln:find("move")
                or ln:find("walk") or ln:find("run") or ln:find("chase") or ln:find("patrol")
                or ln:find("fast") or ln:find("accel") or ln:find("rate") then child.Value = speed end
        end
    end) end

    -- FORCE 4: Humanoid
    for _, child in ipairs(target:GetDescendants()) do pcall(function()
        if child:IsA("Humanoid") then child.WalkSpeed = absSpeed
            pcall(function() child:SetAttribute("WalkSpeed", absSpeed) end)
            pcall(function() child:SetAttribute("Speed", absSpeed) end) end
    end) end

    -- FORCE 5: Direction
    local sd = spd[target]
    local dir = root.CFrame.LookVector
    if sd and sd.forceLastPos then
        local delta = root.Position - sd.forceLastPos
        if delta.Magnitude > 0.01 then
            local flatDir = Vector3.new(delta.X, 0, delta.Z)
            if flatDir.Magnitude > 0 then dir = flatDir.Unit; sd.lastMoveDir = dir end
        end
    end
    if sd and sd.lastMoveDir then dir = sd.lastMoveDir end
    if reversed then dir = -dir end
    if sd then sd.forceLastPos = root.Position end

    -- FORCE 6: Unanchor
    for _, part in ipairs(allParts) do pcall(function() part.Anchored = false end) end

    -- FORCE 7: Weld parts together
    for _, part in ipairs(allParts) do
        if part ~= root then
            local hasWeld = false
            for _, j in ipairs(part:GetJoints()) do
                if j:IsA("WeldConstraint") or j:IsA("Weld") or j:IsA("Motor6D") then hasWeld = true; break end end
            if not hasWeld then pcall(function()
                local w = Instance.new("WeldConstraint"); w.Name = "SpeedControlWeld"
                w.Part0 = root; w.Part1 = part; w.Parent = root end) end
        end
    end

    -- FORCE 8: BodyVelocity 10^15
    if not root.Anchored then
        local bv = root:FindFirstChild("SpeedControlBV")
        if not bv then bv = Instance.new("BodyVelocity"); bv.Name = "SpeedControlBV"; bv.Parent = root end
        bv.MaxForce = Vector3.new(1e15, 1e15, 1e15); bv.P = 1e8
        bv.Velocity = dir * absSpeed
        pcall(function() root.AssemblyLinearVelocity = dir * absSpeed end)
        pcall(function() root.Velocity = dir * absSpeed end)
    end

    -- FORCE 9: All parts velocity
    for _, part in ipairs(allParts) do pcall(function()
        part.AssemblyLinearVelocity = dir * absSpeed; part.Velocity = dir * absSpeed end) end

    -- FORCE 10: CFrame teleport
    if absSpeed > 0 and dir.Magnitude > 0 then
        local moveAmt = dir * absSpeed * (1/60)
        if target:IsA("Model") then pcall(function() target:PivotTo(target:GetPivot() + moveAmt) end)
        else pcall(function() root.CFrame = root.CFrame + moveAmt end) end
    end
end

local function cleanSpeedControl(target)
    if not target or not target.Parent then return end
    for _, desc in ipairs(target:GetDescendants()) do pcall(function()
        if desc.Name == "SpeedControlBV" or desc.Name == "SpeedControlLV" or desc.Name == "SpeedControlWeld" then desc:Destroy() end
    end) end
end

local function stopSpeedApply()
    if speedApplyConn then speedApplyConn:Disconnect(); speedApplyConn = nil end
    if speedApplyTarget and speedApplyTarget.Parent then
        for _, child in ipairs(speedApplyTarget:GetDescendants()) do pcall(function()
            if child:IsA("Script") or child:IsA("LocalScript") then child.Disabled = false end end) end
        cleanSpeedControl(speedApplyTarget)
    end
    speedApplyTarget = nil; speedApplyActive = false
    spApp.Text = "Apply"; spApp.BackgroundColor3 = Color3.fromRGB(0, 140, 60)
end

local function startSpeedLoop(target)
    if speedApplyConn then speedApplyConn:Disconnect(); speedApplyConn = nil end
    speedApplyActive = true
    forceSpeed(target, selSpeed)
    speedApplyConn = RunService.Heartbeat:Connect(function(dt)
        if not active or not target or not target.Parent then stopSpeedApply(); return end
        local root = getPart(target); if not root or not root.Parent then stopSpeedApply(); return end
        forceSpeed(target, selSpeed)
    end)
end

onSpeedChanged = function()
    if speedApplyActive and speedApplyTarget then forceSpeed(speedApplyTarget, selSpeed) end
end

