-- DOOR SCANNING - FIXED FOR PROXIMITY PROMPTS
-- ============================================
local function scanForDoors()
    aoDoors = {}
    
    local char = LP.Character
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    postLog("SCANNING FOR DOORS...")
    
    -- Proximity Prompt names to detect (interact, HideCF, etc.)
    local promptNames = {
        "interact", "hidecf", "door", "enter", "exit", "open", "use", "activate"
    }
    
    local foundDoors = {}
    
    -- Search for ProximityPrompts
    for _, obj in ipairs(workspace:GetDescendants()) do
        if not obj or not obj.Parent then continue end
        
        -- Check if it's a ProximityPrompt
        if obj:IsA("ProximityPrompt") then
            local promptName = obj.Name:lower()
            
            -- Check if it matches door-related prompt names
            local isDoorPrompt = false
            for _, pName in ipairs(promptNames) do
                if promptName:find(pName) then
                    isDoorPrompt = true
                    break
                end
            end
            
            if isDoorPrompt then
                -- Get the parent Model/Part
                local parent = obj.Parent
                if parent then
                    local part = nil
                    if parent:IsA("BasePart") then
                        part = parent
                    else
                        part = parent:FindFirstChildWhichIsA("BasePart", true)
                    end
                    
                    if part and part.Parent then
                        -- Avoid duplicates
                        local alreadyAdded = false
                        for _, door in ipairs(foundDoors) do
                            if door.Part == part then
                                alreadyAdded = true
                                break
                            end
                        end
                        
                        if not alreadyAdded then
                            table.insert(foundDoors, {
                                Prompt = obj,
                                Part = part,
                                Name = parent.Name,
                                PromptName = obj.Name,
                                Opened = false,
                                Type = "ProximityPrompt"
                            })
                            print("[SCANNER] Found door prompt: " .. obj.Name .. " in " .. parent.Name)
                        end
                    end
                end
            end
        end
    end
    
    aoDoors = foundDoors
    
    -- Sort by distance
    if #aoDoors > 0 then
        table.sort(aoDoors, function(a, b)
            if not a.Part or not b.Part then return false end
            local distA = (root.Position - a.Part.Position).Magnitude
            local distB = (root.Position - b.Part.Position).Magnitude
            return distA < distB
        end)
        postLog("FOUND " .. #aoDoors .. " DOORS - SORTED BY DISTANCE")
    else
        postLog("NO DOORS FOUND")
    end
end

local function getNextUnopedDoor()
    for _, door in ipairs(aoDoors) do
        if door.Opened then continue end
        if not door.Part or not door.Part.Parent then continue end
        if not door.Prompt or not door.Prompt.Parent then continue end
        return door
    end
    return nil
end

local function aoDoorTick()
    if not aoDoorEnabled then return end
    
    local char = LP.Character
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local now = tick()
    
    -- Get next door if needed
    if not currentAODoor or currentAODoor.Opened or not currentAODoor.Part or not currentAODoor.Part.Parent or not currentAODoor.Prompt or not currentAODoor.Prompt.Parent then
        currentAODoor = getNextUnopedDoor()
        if not currentAODoor then
            postLog("AO DOOR: ALL DOORS OPENED - MISSION COMPLETE")
            aoDoorEnabled = false
            return
        end
    end
    
    local doorPart = currentAODoor.Part
    if not doorPart or not doorPart.Parent then
        currentAODoor = getNextUnopedDoor()
        return
    end
    
    local dist = (root.Position - doorPart.Position).Magnitude
    
    -- Teleport if far
    if dist > 8 and now - aoLastTeleport >= aoTeleportDelay then
        pcall(function()
            root.CFrame = doorPart.CFrame * CFrame.new(0, 0, 4)
            aoLastTeleport = now
            postLog("TELEPORTED TO: " .. currentAODoor.Name .. " (" .. math.floor(dist) .. " STUDS)")
        end)
    end
    
    -- Trigger prompt when close (simulate E press)
    if dist <= 20 and now - aoLastEPress >= aoEPressDelay then
        pcall(function()
            -- Fire the proximity prompt
            if currentAODoor.Prompt and currentAODoor.Prompt.Parent then
                currentAODoor.Prompt:InputBegan(Enum.UserInputType.Keyboard, false)
                task.wait(0.1)
                currentAODoor.Prompt:InputEnded(Enum.UserInputType.Keyboard, false)
            end
            
            aoLastEPress = now
            currentAODoor.Opened = true
            postLog("TRIGGERED: " .. currentAODoor.PromptName .. " (" .. currentAODoor.Name .. ")")
        end)
    end
end

