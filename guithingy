    db.BackgroundColor3 = Color3.fromRGB(140, 20, 20); db.Text = "🗑 Delete"; db.TextColor3 = Color3.new(1,1,1)
    db.TextSize = 7; db.Font = Enum.Font.GothamBold; db.BorderSizePixel = 0; db.Parent = e
    Instance.new("UICorner", db).CornerRadius = UDim.new(0, 3)

    rb.MouseButton1Click:Connect(function()
        blacklist[entityName] = nil; blacklistCount -= 1; updateUndoCount()
        e:Destroy(); undoEntries[entityName] = nil
        -- Re-track
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj.Name == entityName and matchesEntityPattern(obj.Name) and not playerChars[obj] and not tracked[obj] then
                task.defer(function() if obj.Parent then track(obj) end end)
            end
        end
    end)

    db.MouseButton1Click:Connect(function()
        e:Destroy(); undoEntries[entityName] = nil
        -- Keep blacklisted but remove undo
    end)

    undoEntries[entityName] = e
    updateUndoCount()
end

