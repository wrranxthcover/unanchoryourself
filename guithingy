-- IMPROVED DOOR SCANNING (DEBUG VERSION)
-- ============================================
local function scanForDoors()
    aoDoors = {}
    
    local char = LP.Character
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    postLog("SCANNING FOR DOORS...")
    
    -- METHOD 1: Look for ProximityPrompt objects
    local promptCount = 0
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            promptCount = promptCount + 1
            local parent = obj.Parent
            print("[DEBUG] Found ProximityPrompt in: " .. parent.Name)
            
            if parent then
                local part = nil
                if parent:IsA("BasePart") then
                    part = parent
                else
                    part = parent:FindFirstChildWhichIsA("BasePart", true)
                end
                
                if part and part.Parent then
                    table.insert(aoDoors, {
                        Prompt = obj,
                        Part = part,
                        Name = parent.Name,
                        Opened = false,
                        Type = "ProximityPrompt"
                    })
                    print("[DEBUG] Added door from ProximityPrompt: " .. parent.Name)
                end
            end
        end
    end
    postLog("Found " .. promptCount .. " ProximityPrompts")
    
    -- METHOD 2: Look for objects with "door" in the name (broader search)
    local doorNameCount = 0
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") or obj:IsA("BasePart") then
            local objName = obj.Name:lower()
            if objName:find("door") or objName:find("gate") or objName:find("entrance") then
                doorNameCount = doorNameCount + 1
                print("[DEBUG] Found door-named object: " .. obj.Name .. " (" .. obj.ClassName .. ")")
                
                local part = nil
                if obj:IsA("BasePart") then
                    part = obj
                else
                    part = obj:FindFirstChildWhichIsA("BasePart", true)
                end
                
                if part and part.Parent then
                    -- Check if already added
                    local alreadyAdded = false
                    for _, door in ipairs(aoDoors) do
                        if door.Part == part then
                            alreadyAdded = true
                            break
                        end
                    end
                    
                    if not alreadyAdded then
                        table.insert(aoDoors, {
                            Prompt = nil,
                            Part = part,
                            Name = obj.Name,
                            Opened = false,
                            Type = "NameMatch"
                        })
                        print("[DEBUG] Added door from name match: " .. obj.Name)
                    end
                end
            end
        end
    end
    postLog("Found " .. doorNameCount .. " door-named objects")
    
    -- Sort by distance
    if #aoDoors > 0 then
        table.sort(aoDoors, function(a, b)
            if not a.Part or not b.Part then return false end
            local distA = (root.Position - a.Part.Position).Magnitude
            local distB = (root.Position - b.Part.Position).Magnitude
            return distA < distB
        end)
        print("[DEBUG] Sorted " .. #aoDoors .. " doors by distance")
    end
end

local function getNextUnopedDoor()
    for _, door in ipairs(aoDoors) do
        if door.Opened then continue end
        if door.Prompt and (not door.Prompt.Parent) then continue end
        if not door.Part or not door.Part.Parent then continue end
        return door
    end
    return nil
end

local function aoDoorTick()
    if not aoDoorEnabled then return end
    
    local char = LP.Character
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local now = tick()
    
    -- Get next door if needed
    if not currentAODoor or currentAODoor.Opened or not currentAODoor.Part or not currentAODoor.Part.Parent then
        currentAODoor = getNextUnopedDoor()
        if not currentAODoor then
            postLog("AO DOOR: No more doors to open")
            aoDoorEnabled = false
            return
        end
    end
    
    local doorPart = currentAODoor.Part
    if not doorPart or not doorPart.Parent then
        currentAODoor = getNextUnopedDoor()
        return
    end
    
    local dist = (root.Position - doorPart.Position).Magnitude
    
    -- Teleport if far
    if dist > 8 and now - aoLastTeleport >= aoTeleportDelay then
        pcall(function()
            root.CFrame = doorPart.CFrame * CFrame.new(0, 0, 4)
            aoLastTeleport = now
            postLog("AO DOOR: Teleported to " .. currentAODoor.Name)
        end)
    end
    
    -- Press E when close
    if dist <= 15 and now - aoLastEPress >= aoEPressDelay then
        pcall(function()
            UIS:SendKeyEvent(true, Enum.KeyCode.E, false, LP)
            task.wait(0.05)
            UIS:SendKeyEvent(false, Enum.KeyCode.E, false, LP)
            aoLastEPress = now
            currentAODoor.Opened = true
            postLog("AO DOOR: Opened " .. currentAODoor.Name .. " (" .. currentAODoor.Type .. ")")
        end)
    end
end

