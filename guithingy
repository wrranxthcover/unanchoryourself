-- ============================================
-- DISTANCE + SPEED + COLOR + ALERT
-- ============================================
RunService.Heartbeat:Connect(function()
    if not active then return end; dFrame += 1; if dFrame < DIST_SKIP then return end; dFrame = 0
    local char = LP.Character; local myR = char and char:FindFirstChild("HumanoidRootPart"); if not myR then return end
    local myP = myR.Position; local now = tick()
    local closestRedName, closestRedDist, closestRedSpeed = nil, math.huge, ""
    local allRed = {}

    for ent, d in pairs(tracked) do
        local tp = d.targetPart; if not tp or not tp.Parent then tp = getEntityPart(ent); d.targetPart = tp end
        if tp and tp.Parent then
            local dist = math.floor((myP - tp.Position).Magnitude)

            -- Speed
            local sd = speedData[ent]; local speedTxt, speedCol = "", Color3.fromRGB(180, 180, 100)
            if sd then
                local dt = now - sd.lastTime
                if dt > 0.1 then
                    local spd = (tp.Position - sd.lastPos).Magnitude / dt
                    sd.lastPos = tp.Position; sd.lastTime = now
                    table.insert(sd.samples, spd); if #sd.samples > 5 then table.remove(sd.samples, 1) end
                    local avg = 0; for _, s in ipairs(sd.samples) do avg += s end; avg = avg / #sd.samples; sd.speed = avg
                    if avg >= FAST_THRESHOLD then speedTxt = "⚡FAST " .. math.floor(avg) .. "s/s"; speedCol = Color3.fromRGB(255, 80, 80)
                    elseif avg >= SLOW_THRESHOLD then speedTxt = "→ " .. math.floor(avg) .. "s/s"; speedCol = Color3.fromRGB(255, 200, 80)
                    elseif avg >= 0.5 then speedTxt = "🐌 " .. string.format("%.1f", avg); speedCol = Color3.fromRGB(120, 180, 120)
                    else speedTxt = "■ Idle"; speedCol = Color3.fromRGB(100, 100, 100) end
                end
            else speedData[ent] = {lastPos = tp.Position, lastTime = now, speed = 0, samples = {}, prevPos = tp.Position, prevTime = now} end

            -- Text
            local tc = dist < 18 and Color3.fromRGB(255, 40, 40) or dist < 50 and Color3.fromRGB(255, 180, 30) or Color3.fromRGB(140, 140, 140)
            if d.distLabel then d.distLabel.Text = dist .. "s"; d.distLabel.TextColor3 = tc end
            if d.entryDist then d.entryDist.Text = dist .. "s"; d.entryDist.TextColor3 = tc end
            if d.speedLabel then d.speedLabel.Text = speedTxt; d.speedLabel.TextColor3 = speedCol end
            if d.entrySpeed then d.entrySpeed.Text = speedTxt; d.entrySpeed.TextColor3 = speedCol end

            -- ESP color
            local ec
            if dist >= 50000 then ec = Color3.fromRGB(255, 255, 255)
            elseif dist >= 25000 then local t = (dist-25000)/25000; ec = Color3.fromRGB(255, 255, math.floor(255*t))
            elseif dist >= 10000 then local t = (dist-10000)/15000; ec = Color3.fromRGB(255, math.floor(140+115*t), 0)
            else local t = math.clamp(dist/10000, 0, 1); ec = Color3.fromRGB(255, math.floor(140*t), 0) end
            if d.highlight then d.highlight.FillColor = ec; d.highlight.OutlineColor = ec end
            if d.nameLabel then d.nameLabel.TextColor3 = ec end
            if d.entryName then d.entryName.TextColor3 = ec end
            if d.entryStroke then d.entryStroke.Color = ec end
            if d.entryDot then d.entryDot.BackgroundColor3 = ec end

            -- Red alert (only if approaching)
            if dist < RED_THRESHOLD and matchesEntityPattern(ent.Name) then
                local approaching = true
                if sd and sd.prevPos then
                    local toPlayer = (myP - tp.Position).Unit
                    local vel = Vector3.zero
                    local pdt = now - (sd.prevTime or now)
                    if pdt > 0 then vel = (tp.Position - sd.prevPos) / pdt end
                    if vel.Magnitude > 0.5 then
                        local dotVal = vel.Unit:Dot(toPlayer)
                        approaching = dotVal > 0.1
                    end
                    sd.prevPos = tp.Position; sd.prevTime = now
                end
                if approaching then
                    allRed[ent.Name] = dist
                    if dist < closestRedDist then closestRedName = ent.Name; closestRedDist = dist; closestRedSpeed = speedTxt end
                end
            end
        end
    end

    if closestRedName then showAlert(closestRedName, closestRedDist, allRed, closestRedSpeed) else hideAlert() end
end)

