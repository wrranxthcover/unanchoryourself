                                pcall(function() if hum:GetState() == Enum.HumanoidStateType.Dead then desp = true; despR = "dead state" end end) end
                            if tp.Position.Y < -50 then desp = true; despR = "fell off map" end
                            if sd.pP and (tp.Position - sd.pP).Magnitude > 500 then desp = true; despR = "teleported" end
                            if not tp.CanCollide and tp.Transparency < 0.1 then
                                if sd.wasCollidable == nil then sd.wasCollidable = true end
                                if sd.wasCollidable then desp = true; despR = "no collision" end end
                            sd.wasCollidable = tp.CanCollide
                            if tp.Anchored and not sd.wasAnchored then sd.idleState = "🔒 Frozen"; sd.idleCol = Color3.fromRGB(100,150,255) end
                            sd.wasAnchored = tp.Anchored
