local function makeToggle(btn, state, onText, offText, callback)
    btn.MouseButton1Click:Connect(function()
        state = not state
        if state then
            btn.Text = onText
            btn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        else
            btn.Text = offText
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
        end
        callback(state)
    end)
end

