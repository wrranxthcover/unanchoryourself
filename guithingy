            local b = ef:FindFirstChild("ViewBtn")
            if b then
                b.Text = "✔"
                b.BackgroundColor3 = Color3.fromRGB(130, 0, 255)
            end
        end
    else
        ViewTopBtn.Text = "None!"
        ViewTopBtn.BackgroundColor3 = Color3.fromRGB(145, 25, 25)
