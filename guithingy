-- Reset keybinds
resetBtn.MouseButton1Click:Connect(function()
    settings.forceInteractKey = Enum.KeyCode.G
    settings.unanchorKey = Enum.KeyCode.H
    settings.toggleGUIKey = Enum.KeyCode.RightShift

    -- Update all keybind buttons
    for _, child in pairs(settingsPage:GetDescendants()) do
        if child:IsA("TextButton") and child.Text:match("^%[") then
            -- Find which keybind this belongs to by checking parent label
            local row = child.Parent
            if row then
                local label = row:FindFirstChildWhichIsA("TextLabel")
                if label then
                    if label.Text:match("Interact") then
                        child.Text = "[G]"
                    elseif label.Text:match("Unanchor") then
                        child.Text = "[H]"
                    elseif label.Text:match("GUI") then
                        child.Text = "[RightShift]"
                    end
                end
            end
        end
    end

    child = nil
    updateHintText()
    statusLabel.Text = "Status: 🔃 Keybinds reset!"
    statusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
end)

-- // ===== KEYBIND LISTENER ===== //
UIS.InputBegan:Connect(function(input, processed)
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end

    -- If waiting for a keybind change
    if waitingForKey then
        local key = input.KeyCode
        if key == Enum.KeyCode.Escape then
            -- Cancel
            waitingForKey.button.Text = "[" .. settings[waitingForKey.settingKey].Name .. "]"
            waitingForKey.button.BackgroundColor3 = Color3.fromRGB(0, 100, 255)
            statusLabel.Text = "Status: ❌ Cancelled"
            statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            waitingForKey = nil
            return
        end

        settings[waitingForKey.settingKey] = key
        waitingForKey.button.Text = "[" .. key.Name .. "]"
        waitingForKey.button.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        tweenService:Create(waitingForKey.button, TweenInfo.new(0.5), {
            BackgroundColor3 = Color3.fromRGB(0, 100, 255)
        }):Play()

        statusLabel.Text = "Status: ✅ Bound to [" .. key.Name .. "]"
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)

        updateHintText()
        waitingForKey = nil
        return
    end

    if processed then return end

    -- Keybind actions
    if input.KeyCode == settings.forceInteractKey then
        forceInteract()
    elseif input.KeyCode == settings.unanchorKey then
        unanchor()
    elseif input.KeyCode == settings.toggleGUIKey then
        if frame.Visible then
            minimized = true
            frame.Visible = false
            toggleBtn.Visible = true
        else
            minimized = false
            frame.Visible = true
            toggleBtn.Visible = false
        end
    end
end)

