                                        if pn:find("stair") or pn:find("step") or pn:find("ladder") or pn:find("climb") then nS = true end
                                        if pn:find("chest") or pn:find("crate") or pn:find("box") or pn:find("loot") then nC = true end
                                        if pn:find("hall") or pn:find("corridor") or pn:find("passage") or pn:find("tunnel") then nH = true end
