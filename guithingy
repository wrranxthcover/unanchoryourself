workspace.DescendantAdded:Connect(function(obj)
    if not scannerActive then return end
    task.wait(0.15)
    if obj:IsA("Model") and isKnownEntity(obj) and not entityESPObjects[obj] then
        createESP(obj)
        createListEntry(obj)
        local total = 0
        for _ in pairs(entityESPObjects) do total += 1 end
        EntityCountLabel.Text = "Entities Detected: " .. total
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    if entityESPObjects[obj] then
        removeESP(obj)
        removeListEntry(obj)
        if currentlyViewing == obj then stopViewMode() end
    end
end)

