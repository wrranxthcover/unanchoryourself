-- ============================================
-- VIEW MODE
-- ============================================

local function stopViewMode()
    viewModeActive = false
    
    if viewConnection then
        viewConnection:Disconnect()
        viewConnection = nil
    end
    
    Camera.CameraType = Enum.CameraType.Custom
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then Camera.CameraSubject = hum end
    end
    
    ViewPanel.Visible = false
    ViewTopBtn.BackgroundColor3 = Color3.fromRGB(80, 0, 170)
    ViewTopBtn.Text = "👁 View"
    
    for _, frame in pairs(entryMap) do
        local b = frame:FindFirstChild("ViewBtn")
        if b then
            b.Text = "👁"
            b.BackgroundColor3 = Color3.fromRGB(80, 0, 170)
        end
    end
    
    currentlyViewing = nil
end

local function startViewMode(entity)
    if viewModeActive then stopViewMode() end
    
    local data = entityESPObjects[entity]
    local root = data and data.targetPart
    
    if not root or not root.Parent then
        root = entity:FindFirstChild("HumanoidRootPart")
            or entity:FindFirstChild("Head")
            or entity:FindFirstChild("Torso")
            or entity.PrimaryPart
            or entity:FindFirstChildWhichIsA("BasePart")
    end
    
    if not root then return end
    
    viewModeActive = true
    currentlyViewing = entity
    ViewPanel.Visible = true
    ViewingLabel.Text = "👁 Viewing: " .. entity.Name
    ViewTopBtn.Text = "👁 ..."
    ViewTopBtn.BackgroundColor3 = Color3.fromRGB(130, 0, 255)
    
    Camera.CameraType = Enum.CameraType.Scriptable
    
    local tween = TweenService:Create(Camera,
        TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        { CFrame = CFrame.new(root.Position + Vector3.new(0, 6, 10), root.Position) }
    )
    tween:Play()
    
    tween.Completed:Connect(function()
        if not viewModeActive or currentlyViewing ~= entity then return end
        
        viewConnection = RunService.RenderStepped:Connect(function()
            if not viewModeActive or not entity or not entity.Parent then
                stopViewMode()
                return
            end
            
            if not root or not root.Parent then
                root = entity:FindFirstChild("HumanoidRootPart")
                    or entity:FindFirstChild("Head")
                    or entity.PrimaryPart
                    or entity:FindFirstChildWhichIsA("BasePart")
                if not root then stopViewMode() return end
            end
            
            local desired = CFrame.new(root.Position + Vector3.new(0, 6, 10), root.Position)
            Camera.CFrame = Camera.CFrame:Lerp(desired, 0.08)
        end)
    end)
end

-- ============================================
-- ESP FUNCTIONS
-- ============================================

local function removeESP(entity)
    local data = entityESPObjects[entity]
    if not data then return end
    
    pcall(function() if data.highlight then data.highlight:Destroy() end end)
    pcall(function() if data.billboard then data.billboard:Destroy() end end)
    if data.destroyConn then data.destroyConn:Disconnect() end
    
    entityESPObjects[entity] = nil
    
    if currentlyViewing == entity then stopViewMode() end
end

local function createESP(entity)
    if entityESPObjects[entity] then return end
    
    local color = getEntityColor(entity.Name)
    local espData = {}
    
    -- Highlight
    local hl = Instance.new("Highlight")
    hl.Name = "ESP_HL"
    hl.Adornee = entity
    hl.FillColor = color
    hl.FillTransparency = 0.55
    hl.OutlineColor = color
    hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Enabled = espEnabled
    hl.Parent = entity
    espData.highlight = hl
    
    -- Find root part
    local root = entity:FindFirstChild("HumanoidRootPart")
        or entity:FindFirstChild("Head")
        or entity:FindFirstChild("Torso")
        or entity.PrimaryPart
        or entity:FindFirstChildWhichIsA("BasePart")
    espData.targetPart = root
    
    -- Billboard nametag
    if root then
        local bb = Instance.new("BillboardGui")
        bb.Name = "ESP_BB"
        bb.Adornee = root
        bb.Size = UDim2.new(0, 140, 0, 45)
        bb.StudsOffset = Vector3.new(0, 4.5, 0)
        bb.AlwaysOnTop = true
        bb.MaxDistance = math.huge
        bb.Enabled = namesEnabled
        bb.Parent = root
        
        local nameTag = Instance.new("TextLabel")
        nameTag.Size = UDim2.new(1, 0, 0.55, 0)
        nameTag.BackgroundTransparency = 1
        nameTag.Text = "⚠ " .. entity.Name
        nameTag.TextColor3 = color
        nameTag.TextSize = 15
        nameTag.Font = Enum.Font.GothamBold
        nameTag.TextStrokeTransparency = 0.1
        nameTag.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        nameTag.Parent = bb
        
        local distTag = Instance.new("TextLabel")
        distTag.Name = "DistLabel"
        distTag.Size = UDim2.new(1, 0, 0.4, 0)
        distTag.Position = UDim2.new(0, 0, 0.55, 0)
        distTag.BackgroundTransparency = 1
        distTag.Text = "?"
        distTag.TextColor3 = Color3.fromRGB(180, 180, 180)
        distTag.TextSize = 11
        distTag.Font = Enum.Font.GothamSemibold
        distTag.TextStrokeTransparency = 0.3
        distTag.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        distTag.Parent = bb
        
        espData.billboard = bb
        espData.distLabel = distTag
    end
    
    -- Auto-cleanup
    espData.destroyConn = entity.AncestryChanged:Connect(function(_, parent)
        if not parent then
            removeESP(entity)
            if entryMap[entity] then
                entryMap[entity]:Destroy()
                entryMap[entity] = nil
                sortOrder[entity] = nil
            end
            local c = 0
            for _ in pairs(entryMap) do c += 1 end
            EmptyLabel.Visible = c == 0
        end
    end)
    
    entityESPObjects[entity] = espData
end

