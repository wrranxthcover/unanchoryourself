RunService.Heartbeat:Connect(function()
    if not active then return end; dF += 1; if dF < dSkip then return end; dF = 0
    local char = LP.Character; local myR = char and char:FindFirstChild("HumanoidRootPart"); if not myR then return end
    local myP = myR.Position; local now = tick(); local cRN, cRD, cRS, cRT = nil, math.huge, "", "? UNKNOWN"; local allR = {}
    local nearestDist = math.huge; local nearestName = "---"
    local highestThreat = "✦ SAFE"
    local threatPriority = {["☠ LETHAL"]=4, ["⚠ DANGER"]=3, ["◆ NEUTRAL"]=2, ["✦ SAFE"]=1, ["? UNKNOWN"]=0}

    for ent, d in pairs(tracked) do
        local tp = d.targetPart; if not tp or not tp.Parent then tp = getPart(ent); d.targetPart = tp end
        if tp and tp.Parent then
            local dist = math.floor((myP-tp.Position).Magnitude)
            local threat = getThreat(ent.Name)

            if dist < nearestDist then nearestDist = dist; nearestName = getDisplayName(ent) end
            if (threatPriority[threat] or 0) > (threatPriority[highestThreat] or 0) and dist < RED_THRESH then highestThreat = threat end

            -- Proximity warnings
            local sd = spd[ent]
            if sd and not isMinion(ent.Name) then
                if dist < WARN_ZONE and not sd.warnedClose then
                    sd.warnedClose = true
                    showWarning(getDisplayName(ent), dist, getSurvivalTip(ent.Name), threat)
                elseif dist >= WARN_ZONE then
                    sd.warnedClose = false
                end
                if dist < KILL_ZONE and not sd.warnedKill then
                    sd.warnedKill = true
                    showWarning("⚠ " .. getDisplayName(ent) .. " EXTREMELY CLOSE!", dist, getSurvivalTip(ent.Name), threat)
                elseif dist >= KILL_ZONE then
                    sd.warnedKill = false
                end
            end

            local sTxt, sCol = "", Color3.fromRGB(180,180,100)
            if sd then local dt = now - sd.lT
                if dt > 0.1 then
                    local s = (tp.Position-sd.lP).Magnitude/dt
                    sd.totalDist = (sd.totalDist or 0) + (tp.Position-sd.lP).Magnitude
                    sd.lP = tp.Position; sd.lT = now
                    table.insert(sd.sa, s); if #sd.sa > 8 then table.remove(sd.sa, 1) end
                    local avg = 0; for _, v in ipairs(sd.sa) do avg += v end; avg = avg/#sd.sa; sd.sp = avg
                    if avg > (sd.maxSpeed or 0) then sd.maxSpeed = avg end

                    if avg >= FAST_THRESH then
                        sTxt = "⚡ RUSHING "..math.floor(avg).." [peak:"..math.floor(sd.maxSpeed or 0).."]"
                        sCol = Color3.fromRGB(255,40,40)
                    elseif avg >= SLOW_THRESH then
                        local approaching = false
                        if sd.pP then approaching = (myP - tp.Position).Magnitude < (myP - sd.pP).Magnitude end
                        if approaching then sTxt = "🔴 APPROACHING "..math.floor(avg); sCol = Color3.fromRGB(255,100,50)
                        else sTxt = "🟢 RETREATING "..math.floor(avg); sCol = Color3.fromRGB(80,200,80) end
                    elseif avg >= 0.5 then
                        sTxt = "🐌 Creeping "..string.format("%.1f", avg); sCol = Color3.fromRGB(120,180,120)
                    else
                        if not sd.idleCheck or now - sd.idleCheck > 0.8 then
                            sd.idleCheck = now; sd.idleState = "■ Stationary"; sd.idleCol = Color3.fromRGB(100,100,100)
                            local desp, despR = false, ""
                            if tp.Transparency > 0.3 then desp = true; despR = "fading" end
                            if not sd.lSize then sd.lSize = tp.Size end
                            if tp.Size.Magnitude < sd.lSize.Magnitude * 0.8 then desp = true; despR = "shrinking" end
                            sd.lSize = tp.Size
                            if ent.Parent then local pn = ent.Parent.Name:lower()
                                if pn:find("debris") or pn:find("trash") or pn:find("remove") or pn:find("destroy")
                                    or pn:find("dead") or pn:find("gone") or pn:find("delete") or pn:find("cleanup") then
                                    desp = true; despR = "in " .. ent.Parent.Name end end
                            local hum = ent:FindFirstChildWhichIsA("Humanoid")
