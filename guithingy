-- ============================================
-- HELPER FUNCTIONS
-- ============================================

local function isBlacklisted(name)
    local lower = name:lower()
    -- Exact match
    if BLACKLIST_NAMES[lower] then return true end
    -- Partial match for door-related
    if lower:find("door") then return true end
    if lower:find("room") and not lower:find("entity") then return true end
    if lower:find("baseplate") then return true end
    if lower:find("spawn") and not lower:find("entity") then return true end
    return false
end

local function isPlayerCharacter(model)
    for _, player in pairs(Players:GetPlayers()) do
        if player.Character == model then
            return true
        end
    end
    return false
end

local function getEntityColor(name)
    for key, color in pairs(ENTITY_COLORS) do
        if name:lower():find(key:lower()) then
            return color
        end
    end
    return ENTITY_COLORS["Default"]
end

-- ============================================
-- CORE DETECTION — STRICT
-- ============================================

local function isKnownEntity(model)
    -- Must be a Model
    if not model:IsA("Model") then return false end

    -- Never a player
    if isPlayerCharacter(model) then return false end

    -- Never blacklisted
    if isBlacklisted(model.Name) then return false end

    local nameLower = model.Name:lower()

    -- Check against known entity list (exact or partial)
    for entityName, _ in pairs(KNOWN_ENTITIES) do
        if nameLower == entityName:lower() or nameLower:find(entityName:lower()) then
            return true
        end
    end

    return false
end

-- Scan workspace for entities
-- Looks inside common folders AND root workspace
local function scanForEntities()
    local found = {}
    local seen = {}

    local function scanDescendants(root)
        for _, obj in pairs(root:GetDescendants()) do
            if not seen[obj] and obj:IsA("Model") and isKnownEntity(obj) then
                seen[obj] = true
                table.insert(found, obj)
            end
        end
    end

    -- Scan root workspace
    scanDescendants(workspace)

    -- Also check direct children of workspace in case entities are top-level
    for _, child in pairs(workspace:GetChildren()) do
        if not seen[child] and child:IsA("Model") and isKnownEntity(child) then
            seen[child] = true
            table.insert(found, child)
        end
    end

    return found
end

