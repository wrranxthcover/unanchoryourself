workspace.DescendantAdded:Connect(function(obj)
    if not active then return end
    if matchesEntityPattern(obj.Name) and not playerChars[obj] and not isBlacklisted(obj.Name) then
        task.defer(function()
            if not obj.Parent or tracked[obj] then return end
            if obj:IsA("Model") then
                local tries = 0
                while tries < 15 do
                    if obj:FindFirstChildWhichIsA("BasePart", true) then break end
                    tries += 1; task.wait(0.2); if not obj.Parent then return end
                end
            end
            if obj.Parent and not tracked[obj] then track(obj) end
        end)
    end
    if isMinionName(obj.Name) then
        task.defer(function()
            if not obj.Parent then return end
            local p = obj.Parent
            if tracked[p] and not tracked[obj] then track(obj); return end
            local gp = p and p.Parent
            if gp and tracked[gp] and not tracked[obj] then track(obj) end
        end)
    end
    if obj:IsA("BasePart") then
        task.defer(function()
            if not obj.Parent then return end
            local p = obj.Parent
            if p and matchesEntityPattern(p.Name) and not playerChars[p] and not isBlacklisted(p.Name) and not tracked[p] then track(p) end
            local gp = p and p.Parent
            if gp and gp ~= workspace and matchesEntityPattern(gp.Name) and not playerChars[gp] and not isBlacklisted(gp.Name) and not tracked[gp] then track(gp) end
        end)
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    if tracked[obj] then untrack(obj) end
end)

