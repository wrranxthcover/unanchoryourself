        if not scannerActive then return end
        task.wait(0.1)
        if descendant:IsA("Model") and isEntity(descendant) then
            createESP(descendant)
            local color = getEntityColor(descendant.Name)
            createEntityListEntry(descendant, color)
        end
    end)

    container.DescendantRemoving:Connect(function(descendant)
        if not scannerActive then return end
        if entityESPObjects[descendant] then
            removeESP(descendant)
            removeEntityListEntry(descendant)
        end
    end)
end

