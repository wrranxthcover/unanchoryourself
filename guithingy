                                elseif nV then sd.idleState = "🕳 Near Vent!"; sd.idleCol = Color3.fromRGB(160,160,160)
                                elseif nS then sd.idleState = "🪜 At Stairs!"; sd.idleCol = Color3.fromRGB(180,200,140)
                                elseif nC then sd.idleState = "📦 Near Chest!"; sd.idleCol = Color3.fromRGB(255,220,80)
                                elseif nH then sd.idleState = "🏚 In Hallway!"; sd.idleCol = Color3.fromRGB(160,140,120) end
                                local yP = tp.Position.Y
                                if yP > 30 then sd.idleState = (sd.idleState or "■ Stationary").." [HIGH]"
                                elseif yP < -10 then sd.idleState = (sd.idleState or "■ Stationary").." [BELOW]" end
                            end
                        end; sTxt = sd.idleState or "■ Stationary"; sCol = sd.idleCol or Color3.fromRGB(100,100,100)
                    end
                end
            else spd[ent] = {lP=tp.Position, lT=now, sp=0, sa={}, pP=tp.Position, pT=now,
                idleCheck=0, idleState="■ Stationary", idleCol=Color3.fromRGB(100,100,100), lSize=tp.Size,
                forceLastPos=tp.Position, lastMoveDir=nil, maxSpeed=0, totalDist=0,
                wasCollidable=tp.CanCollide, wasAnchored=tp.Anchored, warnedClose=false, warnedKill=false} end

            local tc = dist<KILL_ZONE and Color3.fromRGB(255,30,30) or dist<DANGER_CLOSE and Color3.fromRGB(255,180,30) or Color3.fromRGB(140,140,160)
            if d.distLabel then d.distLabel.Text = dist.."s"; d.distLabel.TextColor3 = tc end
            if d.entryDist then d.entryDist.Text = dist.."s"; d.entryDist.TextColor3 = tc end
            if d.speedLabel then d.speedLabel.Text = sTxt; d.speedLabel.TextColor3 = sCol end
            if d.entrySpeed then d.entrySpeed.Text = sTxt; d.entrySpeed.TextColor3 = sCol end

            local ec
            if dist < KILL_ZONE then ec = Color3.fromRGB(255, 0, 0)
            elseif dist < DANGER_CLOSE then local t = (dist-KILL_ZONE)/(DANGER_CLOSE-KILL_ZONE); ec = Color3.fromRGB(255, math.floor(180*t), 0)
            elseif dist < 200 then local t = (dist-DANGER_CLOSE)/(200-DANGER_CLOSE); ec = Color3.fromRGB(255, math.floor(180+75*t), math.floor(80*t))
            else ec = color end
            if d.highlight then d.highlight.FillColor = ec; d.highlight.OutlineColor = ec
                d.highlight.FillTransparency = dist < KILL_ZONE and 0.3 or 0.5 end
            if d.nameLabel then d.nameLabel.TextColor3 = ec end; if d.entryName then d.entryName.TextColor3 = ec end
            if d.entryStroke then d.entryStroke.Color = ec end

            local shouldAlert = matchPat(ent.Name) and not isMinion(ent.Name)
            if dist < RED_THRESH and shouldAlert then local appr = true
                if sd and sd.pP then local toP = (myP-tp.Position).Unit; local vel = Vector3.zero
                    local pdt = now-(sd.pT or now); if pdt > 0 then vel = (tp.Position-sd.pP)/pdt end
                    if vel.Magnitude > 0.5 then appr = vel.Unit:Dot(toP) > 0.1 end; sd.pP = tp.Position; sd.pT = now end
                if appr then local alertName = getDisplayName(ent); allR[alertName] = dist
                    if dist < cRD then cRN = alertName; cRD = dist; cRS = sTxt; cRT = threat end end end
        end
    end

    timeL.Text = "⏱ " .. formatTime(tick() - sessionStart)
    statL.Text = "📊 " .. totalDetected .. " det | " .. totalAlerts .. " alerts"
    nearL.Text = "📡 " .. (nearestDist < math.huge and (nearestName .. " " .. nearestDist .. "s") or "---")
    threatL.Text = "🛡 " .. highestThreat; threatL.TextColor3 = getThreatCol(highestThreat)
    if cRN then showAl(cRN, cRD, allR, cRS, cRT) else hideAl() end
    updateRadar()
end)

