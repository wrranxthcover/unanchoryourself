-- Deep cleaning utility to strip all common, custom, math, and foreign Unicode characters for identification
local function cleanSymbols(str)
    -- Normalize/strip common Latin extensions (ï -> i, ÿ -> y, ë -> e, ö -> o, etc.)
    local replacements = {
        ["\195\164"] = "a", ["\195\166"] = "ae", ["\195\182"] = "o", ["\195\188"] = "u",
        ["\195\175"] = "i", ["\195\171"] = "e", ["\195\191"] = "y", ["\195\165"] = "a",
        ["\195\184"] = "o", ["\194\175"] = "i", ["\195\143"] = "X", ["\195\145"] = "N",
        ["\197\147"] = "oe", ["\195\159"] = "ss"
    }
    for utf8Char, asciiRepl in pairs(replacements) do
        str = str:gsub(utf8Char, asciiRepl)
    end
    
    -- Strip non-alphanumeric, miscellaneous symbols, brackets, dashes, and whitespace
    str = str:gsub("[%s%p%c%s]", "")
    -- Remove any remaining math/foreign symbol blocks in Lua Unicode bounds
    str = str:gsub("[%z\1-\127]", function(c)
        if c:match("%w") then return c else return "" end
    end)
    return str:lower()
end

local function matchPat(name)
    local cleanName = cleanSymbols(name)
    if KNOWN_ENTITIES[cleanName] then return true end
    
    -- Detect standard Sub-Floor formats e.g. A-60, A-120, A-200, A-2000, A-ï-60
    local dp = name:find("%-(%d+)$")
    if dp then
        local pre = name:sub(1, dp-1)
        local num = tonumber(name:sub(dp+1))
        if num and num >= 1 and num <= 2000 then
            local c = pre:gsub("\195\175","X"):gsub("\195\143","X")
            if #c >= 1 and #c <= 5 then
                local st = c:gsub("X","")
                if st == "" or st:match("^[A-Za-z]+$") then return true end
            end
        end
    end
    
    -- Detect custom modifier variants e.g. Mob9, MOB18, Mob-ï-2
    local mn = name:match("^[Mm][Oo][Bb](%d+)$")
    if mn then 
        local n = tonumber(mn)
        if n and n >= 1 and n <= 50 then return true end 
    end
    
    -- Fallback: If it's not a player but contains known entity substrings along with Unicode symbols
    for known in pairs(KNOWN_ENTITIES) do
        if cleanName:find(known) then return true end
    end
    
    return false
end

local function isMinion(name) local l = name:lower(); return l == "eye" or l == "mouth" end

local function getDisplayName(entity)
    local l = entity.Name:lower()
    if l == "eye" or l == "mouth" then
        local parent = entity.Parent
        if parent then
            if matchPat(parent.Name) then return parent.Name .. "'s " .. entity.Name end
            local gp = parent.Parent
            if gp and matchPat(gp.Name) then return gp.Name .. "'s " .. entity.Name end
        end
    end
    return entity.Name
end

local function getPrefix(name)
    if name:match("^[Mm][Oo][Bb]%d+$") then return "MOB" end
    local l = name:lower(); if l == "eye" or l == "mouth" then return l end
    if KNOWN_ENTITIES[l] then return name end
    local dp = name:find("%-(%d+)$"); if not dp then return name end; return name:sub(1, dp-1)
end

local function getNum(name) return tonumber(name:match("(%d+)$")) or 0 end

local cCache = {}
local function getCol(name)
    if cCache[name] then return cCache[name] end
    local p = getPrefix(name); local h = 0
    for i = 1, #p do h = h + string.byte(p,i)*14 + i*53 end
    local c = Color3.fromHSV((h%360)/360, 0.85, 1); cCache[name] = c; return c
end

local function formatTime(s)
    local m = math.floor(s/60); local sec = math.floor(s%60)
    return string.format("%02d:%02d", m, sec)
end

