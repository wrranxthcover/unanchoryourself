-- // ===== CORE FUNCTIONS ===== //

local function getCharacter()
    return player.Character or player.CharacterAdded:Wait()
end

local function getHRP()
    local char = getCharacter()
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function unanchor()
    local character = getCharacter()
    local count = 0

    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.Anchored then
            part.Anchored = false
            count = count + 1
        end
    end

    pcall(function()
        if character:FindFirstChild("Humanoid") then
            character.Humanoid:ChangeState(Enum.HumanoidStateType.Running)
        end
        if character:FindFirstChild("HumanoidRootPart") then
            character.HumanoidRootPart.Velocity = Vector3.new(0, 10, 0)
        end
    end)

    if count > 0 then
        statusLabel.Text = "Status: ✅ Unanchored " .. count .. " parts!"
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
    else
        statusLabel.Text = "Status: ⚠️ Already unanchored"
        statusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    end

    unanchorBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
    tweenService:Create(unanchorBtn, TweenInfo.new(0.5), {
        BackgroundColor3 = Color3.fromRGB(0, 100, 255)
    }):Play()
end

local function findNearestPrompt()
    local hrp = getHRP()
    if not hrp then return nil, math.huge end

    local closest = nil
    local closestDist = math.huge

    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            pcall(function()
                local parent = v.Parent
                local part = nil
                if parent:IsA("BasePart") then
                    part = parent
                elseif parent:FindFirstChildWhichIsA("BasePart") then
                    part = parent:FindFirstChildWhichIsA("BasePart")
                end
                if part then
                    local dist = (part.Position - hrp.Position).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        closest = v
                    end
                end
            end)
        end
    end

    return closest, closestDist
end

local function forceInteract()
    local prompt, dist = findNearestPrompt()

    if prompt then
        pcall(function()
            prompt.MaxActivationDistance = 25
            prompt.HoldDuration = 0
            prompt.Enabled = true
        end)

        pcall(function()
            prompt:InputHoldBegin()
            task.wait(0.15)
            prompt:InputHoldEnd()
        end)

        pcall(function()
            fireproximityprompt(prompt)
        end)

        pcall(function()
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("ClickDetector") then
                    local p = v.Parent
                    if p and p:IsA("BasePart") then
                        local hrp = getHRP()
                        if hrp and (p.Position - hrp.Position).Magnitude < 15 then
                            fireclickdetector(v)
                        end
                    end
                end
            end
        end)

        pcall(function()
            VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game)
            task.wait(0.1)
            VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game)
        end)

        statusLabel.Text = "Status: 🚪 Door opened! (Dist: " .. math.floor(dist) .. ")"
        statusLabel.TextColor3 = Color3.fromRGB(0, 200, 255)
    else
        pcall(function()
            VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game)
            task.wait(0.15)
            VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game)
        end)

        statusLabel.Text = "Status: ❌ No door nearby"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    end

    interactBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 255)
    tweenService:Create(interactBtn, TweenInfo.new(0.5), {
        BackgroundColor3 = Color3.fromRGB(130, 0, 200)
    }):Play()
end

