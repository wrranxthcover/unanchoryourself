-- ============================================
-- INITIAL SCAN
-- ============================================

local function initialScan()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if isEntity(obj) then track(obj) end
    end
end

-- ============================================
-- LIVE DETECTION
-- ============================================

workspace.DescendantAdded:Connect(function(obj)
    if not active then return end

    if matchesEntityPattern(obj.Name) and not playerChars[obj] then
        task.defer(function()
            if not obj.Parent or tracked[obj] then return end
            if obj:IsA("Model") then
                local tries = 0
                while tries < 15 do
                    if obj:FindFirstChildWhichIsA("BasePart", true) then break end
                    tries += 1
                    task.wait(0.2)
                    if not obj.Parent then return end
                end
            end
            if obj.Parent and not tracked[obj] then
                track(obj)
            end
        end)
    end

    if obj:IsA("BasePart") then
        task.defer(function()
            if not obj.Parent then return end
            local parent = obj.Parent
            if parent and matchesEntityPattern(parent.Name) and not playerChars[parent] and not tracked[parent] then
                track(parent)
            end
            local gp = parent and parent.Parent
            if gp and gp ~= workspace and matchesEntityPattern(gp.Name) and not playerChars[gp] and not tracked[gp] then
                track(gp)
            end
        end)
    end

    if obj:IsA("Model") or obj:IsA("Folder") then
        task.defer(function()
            if not obj.Parent then return end
            for _, child in ipairs(obj:GetChildren()) do
                if matchesEntityPattern(child.Name) and not playerChars[child] and not tracked[child] then
                    track(child)
                end
            end
        end)
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    if tracked[obj] then untrack(obj) end
end)

-- ============================================
-- PERIODIC RESCAN
-- ============================================

task.spawn(function()
    while active do
        task.wait(3)
        for _, obj in ipairs(workspace:GetDescendants()) do
            if isEntity(obj) and not tracked[obj] then
                track(obj)
            end
        end
    end
end)

-- ============================================
-- DISTANCE UPDATE
-- ============================================

RunService.Heartbeat:Connect(function()
    if not active then return end
    dFrame += 1
    if dFrame < DIST_SKIP then return end
    dFrame = 0

    local char = LocalPlayer.Character
    local myR = char and char:FindFirstChild("HumanoidRootPart")
    if not myR then return end
    local myP = myR.Position

    for ent, d in pairs(tracked) do
        local tp = d.targetPart
        if not tp or not tp.Parent then
            tp = getEntityPart(ent)
            d.targetPart = tp
        end
        if tp and tp.Parent then
            local dist = math.floor((myP - tp.Position).Magnitude)
            local col = dist < 18 and Color3.fromRGB(255, 40, 40)
                or dist < 50 and Color3.fromRGB(255, 180, 30)
                or Color3.fromRGB(140, 140, 140)
            local txt = dist .. "s"
            if d.distLabel then d.distLabel.Text = txt; d.distLabel.TextColor3 = col end
            if d.entryDist then d.entryDist.Text = txt; d.entryDist.TextColor3 = col end
        end
    end
end)

